@model ProductDetailViewModel
@using System.Text.RegularExpressions
@*
    Chi tiết sản phẩm (/san-pham/{slug}).
*@
@{
    // Helper function để lấy YouTube ID từ URL
    string GetYouTubeId(string url)
    {
        if (string.IsNullOrEmpty(url)) return "";
        var reg = new Regex(@"(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/|youtube\.com\/shorts\/)([^""&?\/\s]{11})", RegexOptions.IgnoreCase);
        var match = reg.Match(url);
        return match.Success ? match.Groups[1].Value : "";
    }
    var videoId = GetYouTubeId(Model.Product.Content?.VideoUrl ?? "");
}

<div class="max-w-7xl mx-auto px-4 py-8" x-data="{ lightbox: { open: false, src: '', alt: '' } }">
    @* ===== LIGHTBOX MODAL ===== *@
    <template x-teleport="body">
        <div x-show="lightbox.open" 
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100"
             x-transition:leave="transition ease-in duration-200"
             x-transition:leave-start="opacity-100"
             x-transition:leave-end="opacity-0"
             class="fixed inset-0 z-[100] flex items-center justify-center bg-black/90 p-4"
             @@keydown.escape.window="lightbox.open = false"
             x-cloak>
            <button @@click="lightbox.open = false" 
                    class="absolute top-6 right-6 text-white/70 hover:text-white transition-colors">
                <i data-lucide="x" class="w-10 h-10"></i>
            </button>
            <img :src="lightbox.src" :alt="lightbox.alt" 
                 class="max-w-full max-h-full object-contain rounded shadow-2xl"
                 @@click.away="lightbox.open = false" />
        </div>
    </template>

    @* ===== BREADCRUMB ===== *@
    <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center space-x-2 text-sm text-gray-500">
            @foreach (var crumb in Model.Breadcrumbs)
            {
                @if (!crumb.IsActive)
                {
                    <li><a href="@crumb.Url" class="hover:text-primary transition">@crumb.Label</a></li>
                    <li><span class="mx-1">/</span></li>
                }
                else
                {
                    <li class="text-gray-800 font-medium truncate max-w-[200px]">@crumb.Label</li>
                }
            }
        </ol>
    </nav>

    @* ===== PRODUCT MAIN SECTION ===== *@
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 bg-white rounded-2xl shadow-sm p-6 lg:p-10">
        @* Ảnh sản phẩm *@
        <div>
            @if (!string.IsNullOrEmpty(Model.Product.Content?.Image))
            {
                <div class="aspect-square rounded-xl overflow-hidden bg-gray-50 cursor-pointer group relative"
                     @@click="lightbox.open = true; lightbox.src = '@Model.Product.Content.Image'; lightbox.alt = '@Model.Product.Name'">
                    <img src="@Model.Product.Content.Image"
                         alt="@Model.Product.Name"
                         class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                         loading="eager" />
                    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors flex items-center justify-center">
                        <i data-lucide="zoom-in" class="w-10 h-10 text-white opacity-0 group-hover:opacity-100 transition-opacity drop-shadow-md"></i>
                    </div>
                </div>
            }
            else
            {
                <div class="aspect-square rounded-xl bg-gray-100 flex items-center justify-center">
                    <i data-lucide="image-off" class="w-20 h-20 text-gray-300"></i>
                </div>
            }
        </div>

        @* Thông tin sản phẩm *@
        <div class="flex flex-col">
            @* Danh mục *@
            @if (Model.Product.Category != null)
            {
                <a href="/danh-muc/@Model.Product.Category.Slug"
                   class="text-sm text-primary font-medium uppercase tracking-wide mb-2 hover:underline w-fit">
                    @Model.Product.Category.Name
                </a>
            }

            @* Tên sản phẩm *@
            <h1 class="text-3xl font-bold text-gray-900 mb-4">@Model.Product.Name</h1>

            @* SKU + Trạng thái *@
            <div class="flex items-center gap-4 text-sm text-gray-500 mb-6">
                @if (!string.IsNullOrEmpty(Model.Product.Sku))
                {
                    <span>SKU: <strong class="text-gray-700">@Model.Product.Sku</strong></span>
                }
                @if (Model.Product.Status == ProductStatus.OutOfStock)
                {
                    <span class="bg-red-100 text-red-600 px-2 py-0.5 rounded-full text-xs font-medium">Hết hàng</span>
                }
                else
                {
                    <span class="bg-green-100 text-green-600 px-2 py-0.5 rounded-full text-xs font-medium">Còn hàng</span>
                }
            </div>

            @* Giá *@
            <div class="text-3xl font-bold mb-6 @(Model.Product.Finance?.Price.HasValue == true && Model.Product.Finance.ShowPrice ? "text-primary" : "text-gray-600")">
                @PriceHelper.FormatPrice(Model.Product.Finance?.Price, Model.Product.Finance?.ShowPrice ?? true)
            </div>

            @* Mô tả ngắn *@
            @if (!string.IsNullOrEmpty(Model.Product.Content?.Description))
            {
                <div class="prose prose-sm text-gray-600 mb-8 max-w-none">
                    <p>@Model.Product.Content.Description</p>
                </div>
            }

            @* Nút hành động *@
            <div class="flex flex-wrap gap-3 mt-auto">
                <button type="button"
                        class="add-to-cart-btn bg-primary text-white px-8 py-3 rounded-lg font-semibold
                               hover:opacity-90 transition shadow flex items-center gap-2"
                        data-product-id="@Model.Product.Id"
                        data-product-name="@Model.Product.Name"
                        data-product-price="@Model.Product.Finance?.Price"
                        data-product-image="@Model.Product.Content?.Image">
                    <i data-lucide="shopping-cart" class="w-5 h-5"></i>
                    Thêm vào giỏ hàng
                </button>

                <a href="https://zalo.me/0353785710"
                   target="_blank" rel="noopener noreferrer"
                   class="bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold
                          hover:bg-blue-700 transition shadow flex items-center gap-2">
                    <i data-lucide="message-circle" class="w-5 h-5"></i>
                    Liên hệ Zalo
                </a>
            </div>

            @* Thống kê *@
            <div class="flex items-center gap-6 mt-8 pt-6 border-t text-sm text-gray-400">
                <span class="flex items-center gap-1">
                    <i data-lucide="eye" class="w-4 h-4"></i>
                    @(Model.Product.Statistic?.ViewCount ?? 0) lượt xem
                </span>
                <span class="flex items-center gap-1">
                    <i data-lucide="calendar" class="w-4 h-4"></i>
                    @Model.Product.CreatedAt.ToString("dd/MM/yyyy")
                </span>
            </div>
        </div>
    </div>

    @* ===== CONTENT SECTION (Includes Video) ===== *@
    <section class="mt-12 bg-white rounded-2xl shadow-sm overflow-hidden border border-gray-100">
        @* Tiêu đề căn giữa, màu đen, không nền *@
        <div class="py-8 px-6 text-center border-b border-gray-50">
            <h2 class="text-2xl font-bold text-gray-900 uppercase tracking-widest">Thông tin chi tiết</h2>
        </div>
        
        <div class="p-6 lg:p-10 space-y-12">
            @* Video Nhúng (Nằm trong phần chi tiết) *@
            @if (!string.IsNullOrEmpty(videoId))
            {
                <div class="max-w-3xl mx-auto">
                    <div class="aspect-video w-full bg-black rounded-xl overflow-hidden shadow-md">
                        <iframe class="w-full h-full" 
                                src="https://www.youtube.com/embed/@videoId" 
                                title="Product Video" 
                                frameborder="0" 
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                                referrerpolicy="strict-origin-when-cross-origin"
                                allowfullscreen></iframe>
                    </div>
                    <p class="text-center text-xs text-gray-400 mt-3 flex items-center justify-center gap-1">
                        <i data-lucide="play-circle" class="w-3 h-3"></i> Video giới thiệu sản phẩm
                    </p>
                </div>
            }

            @* Content Blocks *@
            @if (Model.Product.Content?.ContentBlocks != null)
            {
                <div id="content-blocks" class="prose max-w-none mx-auto">
                    @* Rendered by JS *@
                </div>
            }
        </div>
    </section>

    @* ===== SẢN PHẨM LIÊN QUAN ===== *@
    @if (Model.RelatedProducts.Count > 0)
    {
        <section class="mt-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Sản phẩm tương tự</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                @foreach (var related in Model.RelatedProducts)
                {
                    <partial name="_ProductCard" model="related" />
                }
            </div>
        </section>
    }
</div>

@* ===== Client-side scripts ===== *@
@section Scripts {
    <script>
        (function() {
            var raw = '@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Product.Content?.ContentBlocks))';
            if (!raw || raw === 'null') return;

            try {
                var blocks = JSON.parse(raw);
                if (!Array.isArray(blocks)) return;

                var container = document.getElementById('content-blocks');
                if (!container) return;

                blocks.forEach(function(block) {
                    switch (block.type) {
                        case 'heading':
                            var h = document.createElement('h3');
                            h.className = 'text-xl font-bold mt-6 mb-3';
                            h.textContent = block.content || '';
                            container.appendChild(h);
                            break;
                        case 'paragraph':
                            var p = document.createElement('p');
                            p.className = 'mb-4 text-gray-700 leading-relaxed';
                            p.textContent = block.content || '';
                            container.appendChild(p);
                            break;
                        case 'image':
                            var img = document.createElement('img');
                            img.src = block.url || '';
                            img.className = 'rounded-lg my-4 max-w-full cursor-pointer hover:opacity-90 transition-opacity shadow-sm';
                            img.onclick = function() {
                                var root = document.querySelector('[x-data]');
                                if (root && root.__x_data_stack) {
                                    var data = root.__x_data_stack[0];
                                    data.lightbox.src = this.src;
                                    data.lightbox.alt = this.alt;
                                    data.lightbox.open = true;
                                }
                            };
                            container.appendChild(img);
                            break;
                        case 'list':
                            var ul = document.createElement('ul');
                            ul.className = 'list-disc pl-6 mb-4 space-y-1';
                            (block.items || []).forEach(function(item) {
                                var li = document.createElement('li');
                                li.className = 'text-gray-700';
                                li.textContent = item;
                                ul.appendChild(li);
                            });
                            container.appendChild(ul);
                            break;
                    }
                });
                if (window.lucide) lucide.createIcons();
            } catch (e) { console.warn(e); }
        })();
    </script>
}
