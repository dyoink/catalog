@model LoginViewModel
@*
    Trang đăng nhập (/dang-nhap).
    Anti-forgery token, validation, ReturnUrl redirect.
*@
@{
    ViewData["Title"] = "Đăng nhập";
    ViewData["MetaDescription"] = "Đăng nhập vào hệ thống quản trị AquaCMS";
}

<div class="min-h-[60vh] flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-md">
        @* Logo *@
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/10 rounded-2xl mb-4">
                <i data-lucide="lock" class="w-8 h-8 text-primary"></i>
            </div>
            <h1 class="text-2xl font-bold text-gray-900">Đăng nhập</h1>
            <p class="text-gray-500 mt-1">Dành cho quản trị viên</p>
        </div>

        @* Error message *@
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 flex items-center gap-2">
                <i data-lucide="alert-circle" class="w-5 h-5 shrink-0"></i>
                <span class="text-sm">@Model.ErrorMessage</span>
            </div>
        }

        @* Form đăng nhập *@
        <form asp-controller="Account" asp-action="Login" asp-area="" method="post"
              class="bg-white rounded-2xl shadow-sm p-8 space-y-5">
            <input type="hidden" asp-for="ReturnUrl" />

            @* Email *@
            <div>
                <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1.5">
                    Email
                </label>
                <div class="relative">
                    <input asp-for="Email" type="email"
                           class="w-full pl-10 pr-4 py-2.5 border border-gray-200 rounded-lg text-sm
                                  focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
                           placeholder="admin@cataloga.com"
                           autocomplete="email"
                           required />
                    <i data-lucide="mail" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400"></i>
                </div>
                <span asp-validation-for="Email" class="text-xs text-red-500 mt-1"></span>
            </div>

            @* Password *@
            <div>
                <label asp-for="Password" class="block text-sm font-medium text-gray-700 mb-1.5">
                    Mật khẩu
                </label>
                <div class="relative">
                    <input asp-for="Password" type="password"
                           class="w-full pl-10 pr-4 py-2.5 border border-gray-200 rounded-lg text-sm
                                  focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
                           placeholder="••••••••"
                           autocomplete="current-password"
                           required />
                    <i data-lucide="key" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400"></i>
                </div>
                <span asp-validation-for="Password" class="text-xs text-red-500 mt-1"></span>
            </div>

            @* Submit *@
            <button type="submit"
                    class="w-full bg-primary text-white py-3 rounded-lg font-semibold
                           hover:opacity-90 transition shadow-sm flex items-center justify-center gap-2">
                <i data-lucide="log-in" class="w-5 h-5"></i>
                Đăng nhập
            </button>
        </form>

        @* Back link *@
        <div class="text-center mt-6">
            <a href="/" class="text-sm text-gray-400 hover:text-primary transition">
                ← Quay về trang chủ
            </a>
        </div>
    </div>
</div>
