@*
    Trang giỏ hàng (/gio-hang).
    Cart data lưu localStorage, render bằng JS.
*@
@{
    ViewData["Title"] = "Giỏ hàng";
    ViewData["MetaDescription"] = "Giỏ hàng sản phẩm";
}

<div class="max-w-4xl mx-auto px-4 py-8">
    @* Breadcrumb *@
    <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center space-x-2 text-sm text-gray-500">
            <li><a href="/" class="hover:text-primary transition">Trang chủ</a></li>
            <li><span class="mx-1">/</span></li>
            <li class="text-gray-800 font-medium">Giỏ hàng</li>
        </ol>
    </nav>

    <h1 class="text-2xl font-bold text-gray-900 mb-6">Giỏ hàng</h1>

    @* Empty state (ẩn khi có items) *@
    <div id="cart-empty" class="text-center py-20 bg-white rounded-xl shadow-sm">
        <i data-lucide="shopping-cart" class="w-16 h-16 text-gray-300 mx-auto mb-4"></i>
        <h3 class="text-lg font-medium text-gray-600 mb-2">Giỏ hàng trống</h3>
        <p class="text-gray-400 mb-6">Hãy thêm sản phẩm vào giỏ hàng</p>
        <a href="/san-pham" class="inline-block bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:opacity-90 transition">
            Xem sản phẩm
        </a>
    </div>

    @* Cart items (render bằng JS) *@
    <div id="cart-content" class="hidden space-y-4">
        <div id="cart-items" class="space-y-3"></div>

        @* Tổng + CTA *@
        <div class="bg-white rounded-xl shadow-sm p-6 mt-6">
            <div class="flex items-center justify-between mb-6">
                <span class="text-gray-600">Tổng cộng:</span>
                <span id="cart-total" class="text-2xl font-bold text-primary"></span>
            </div>

            <div class="flex flex-col sm:flex-row gap-3">
                <a href="https://zalo.me/0353785710" target="_blank" rel="noopener noreferrer"
                   class="flex-1 bg-blue-600 text-white py-3 rounded-lg font-semibold text-center
                          hover:bg-blue-700 transition flex items-center justify-center gap-2">
                    <i data-lucide="message-circle" class="w-5 h-5"></i>
                    Đặt hàng qua Zalo
                </a>
                <button id="clear-cart-btn" type="button"
                        class="px-6 py-3 border border-gray-200 text-gray-500 rounded-lg hover:bg-gray-50 transition">
                    Xóa giỏ hàng
                </button>
            </div>

            <p class="text-sm text-gray-400 mt-4 text-center">
                Nhấn "Đặt hàng qua Zalo" để gửi đơn hàng cho chúng tôi xử lý nhanh nhất.
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var items = Cart.getItems();
            var emptyEl = document.getElementById('cart-empty');
            var contentEl = document.getElementById('cart-content');
            var itemsEl = document.getElementById('cart-items');
            var totalEl = document.getElementById('cart-total');

            function formatPrice(price) {
                if (!price) return 'Liên hệ';
                return new Intl.NumberFormat('vi-VN').format(price) + ' VNĐ';
            }

            function render() {
                items = Cart.getItems();
                if (items.length === 0) {
                    emptyEl.classList.remove('hidden');
                    contentEl.classList.add('hidden');
                    return;
                }

                emptyEl.classList.add('hidden');
                contentEl.classList.remove('hidden');
                itemsEl.innerHTML = '';

                var total = 0;
                items.forEach(function(item) {
                    var subtotal = item.price ? item.price * item.quantity : 0;
                    total += subtotal;

                    var div = document.createElement('div');
                    div.className = 'bg-white rounded-xl shadow-sm p-4 flex items-center gap-4';
                    div.innerHTML =
                        '<div class="w-16 h-16 rounded-lg overflow-hidden shrink-0 bg-gray-100">' +
                            (item.image ? '<img src="' + item.image + '" class="w-full h-full object-cover" />' :
                            '<div class="w-full h-full flex items-center justify-center"><i data-lucide="image-off" class="w-6 h-6 text-gray-300"></i></div>') +
                        '</div>' +
                        '<div class="flex-1 min-w-0">' +
                            '<h3 class="font-medium text-gray-800 truncate">' + item.name + '</h3>' +
                            '<p class="text-sm text-primary font-medium">' + formatPrice(item.price) + '</p>' +
                        '</div>' +
                        '<div class="flex items-center gap-2">' +
                            '<button class="qty-btn w-8 h-8 rounded bg-gray-100 text-gray-600 hover:bg-gray-200" data-id="' + item.id + '" data-action="dec">−</button>' +
                            '<span class="w-8 text-center font-medium">' + item.quantity + '</span>' +
                            '<button class="qty-btn w-8 h-8 rounded bg-gray-100 text-gray-600 hover:bg-gray-200" data-id="' + item.id + '" data-action="inc">+</button>' +
                        '</div>' +
                        '<button class="remove-btn p-2 text-gray-400 hover:text-red-500" data-id="' + item.id + '">' +
                            '<i data-lucide="trash-2" class="w-4 h-4"></i>' +
                        '</button>';
                    itemsEl.appendChild(div);
                });

                totalEl.textContent = total > 0 ? formatPrice(total) : 'Liên hệ báo giá';
                if (window.lucide) lucide.createIcons();
            }

            // Event delegation
            itemsEl.addEventListener('click', function(e) {
                var qtyBtn = e.target.closest('.qty-btn');
                if (qtyBtn) {
                    var id = qtyBtn.dataset.id;
                    var item = items.find(function(i) { return i.id === id; });
                    if (item) {
                        if (qtyBtn.dataset.action === 'inc') Cart.updateQuantity(id, item.quantity + 1);
                        else if (item.quantity > 1) Cart.updateQuantity(id, item.quantity - 1);
                        else Cart.remove(id);
                        render();
                    }
                }

                var removeBtn = e.target.closest('.remove-btn');
                if (removeBtn) {
                    Cart.remove(removeBtn.dataset.id);
                    render();
                }
            });

            document.getElementById('clear-cart-btn')?.addEventListener('click', function() {
                if (confirm('Xóa toàn bộ giỏ hàng?')) {
                    Cart.clear();
                    render();
                }
            });

            render();
        })();
    </script>
}
