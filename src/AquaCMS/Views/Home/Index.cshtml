@model HomeViewModel
@*
    Trang chủ — Banners, Danh mục, Sản phẩm nổi bật, Bài viết mới.
    SEO: JSON-LD Organization structured data.
*@

@section Head {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <style>
        .hero-swiper { width: 100%; height: auto; overflow: hidden; position: relative; }
        .swiper-wrapper { display: flex !important; flex-direction: row !important; }
        .swiper-slide { flex-shrink: 0; width: 100%; height: 100%; position: relative; }
        
        /* Đưa nút vào trong banner */
        .hero-swiper .swiper-button-next, 
        .hero-swiper .swiper-button-prev {
            width: 48px;
            height: 48px;
            background: rgba(0,0,0,0.15);
            border-radius: 50%;
            color: white !important;
            transition: all 0.3s;
            z-index: 20;
        }
        .hero-swiper .swiper-button-next:after, 
        .hero-swiper .swiper-button-prev:after {
            font-size: 20px !important;
            font-weight: bold;
        }
        .hero-swiper .swiper-button-next:hover, 
        .hero-swiper .swiper-button-prev:hover {
            background: rgba(0,0,0,0.4);
            transform: scale(1.1);
        }
        .hero-swiper .swiper-button-prev { left: 24px !important; }
        .hero-swiper .swiper-button-next { right: 24px !important; }

        .animate-fade-in-up {
            animation: fadeInUp 0.8s ease-out forwards;
            opacity: 0;
        }
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .swiper-pagination-bullet-active { background: white !important; }
    </style>
}

@* ===== HERO BANNER SLIDER ===== *@
@if (Model.Settings.ShowBanners && Model.Banners.Count > 0)
{
    <section class="relative group overflow-hidden">
        <!-- Swiper Container -->
        <div class="swiper hero-swiper">
            <div class="swiper-wrapper">
                @foreach (var banner in Model.Banners)
                {
                    <div class="swiper-slide relative bg-gradient-to-br from-sky-50 to-sky-100 overflow-hidden min-h-[500px] flex items-center" 
                         style="@(!string.IsNullOrEmpty(banner.Image) ? $"background-image: url('{banner.Image}'); background-size: cover; background-position: center;" : "")">
                        
                        @if (!string.IsNullOrEmpty(banner.Image))
                        {
                            <div class="absolute inset-0 bg-black/40"></div>
                        }

                        <div class="relative max-w-7xl mx-auto px-4 py-24 sm:py-32 w-full">
                            <div class="max-w-2xl">
                                @if (!string.IsNullOrEmpty(banner.Subtitle))
                                {
                                    <p class="text-white/90 font-semibold text-sm uppercase tracking-wider mb-3 animate-fade-in-up">
                                        @banner.Subtitle
                                    </p>
                                }
                                <h2 class="text-4xl sm:text-6xl font-extrabold text-white leading-tight mb-6 animate-fade-in-up" style="animation-delay: 100ms">
                                    @banner.Title
                                </h2>
                                @if (!string.IsNullOrEmpty(banner.Description))
                                {
                                    <div class="text-lg text-white/80 mb-10 line-clamp-3 animate-fade-in-up" style="animation-delay: 200ms">
                                        @Html.Raw(banner.Description)
                                    </div>
                                }
                                <a href="@(banner.LinkUrl ?? "/san-pham")"
                                   class="inline-block bg-primary text-white px-10 py-4 rounded-full font-bold hover:scale-105 transition-all shadow-xl animate-fade-in-up" style="animation-delay: 300ms; background-color: #2563eb;">
                                    Khám phá ngay
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Navigation Buttons -->
            <div class="swiper-button-next opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="swiper-button-prev opacity-0 group-hover:opacity-100 transition-opacity"></div>
            
            <!-- Pagination -->
            <div class="swiper-pagination !bottom-8"></div>
        </div>
    </section>
}
else if (Model.Settings.ShowBanners && !string.IsNullOrEmpty(Model.Settings.HeroTitle))
{
    @* Fallback cho trường hợp chỉ có SiteSettings Hero *@
    <section class="relative bg-gradient-to-br from-sky-50 to-sky-100 overflow-hidden min-h-[450px] flex items-center" 
             style="@(!string.IsNullOrEmpty(Model.Settings.HeroBackgroundImage) ? $"background-image: url('{Model.Settings.HeroBackgroundImage}'); background-size: cover; background-position: center;" : "")">
        @if (!string.IsNullOrEmpty(Model.Settings.HeroBackgroundImage))
        {
            <div class="absolute inset-0 bg-black/30"></div>
        }
        <div class="relative max-w-7xl mx-auto px-4 py-20 sm:py-32 w-full">
             <div class="max-w-2xl">
                <h1 class="text-4xl sm:text-6xl font-extrabold @(string.IsNullOrEmpty(Model.Settings.HeroBackgroundImage) ? "text-gray-900" : "text-white") mb-6">
                    @Model.Settings.HeroTitle
                </h1>
                <a href="@(Model.Settings.HeroButtonUrl ?? "/san-pham")" class="inline-block bg-primary text-white px-8 py-3 rounded-lg font-bold" style="background-color: #2563eb;">
                    @Model.Settings.HeroButtonText
                </a>
            </div>
        </div>
    </section>
}

@* ===== DANH MỤC SẢN PHẨM ===== *@
@if (Model.Categories.Count > 0)
{
    <section class="max-w-7xl mx-auto px-4 py-12">
        <div class="text-center mb-10">
            <h2 class="text-2xl font-bold text-gray-900 mb-2">Danh mục sản phẩm</h2>
            <div class="w-16 h-1 bg-primary mx-auto rounded-full" style="background-color: #2563eb;"></div>
        </div>

        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-4 sm:gap-6">
            @foreach (var cat in Model.Categories)
            {
                <a href="/danh-muc/@cat.Slug"
                   class="group flex flex-col items-center text-center">
                    <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-full flex items-center justify-center p-0.5 group-hover:shadow-md transition-all duration-300 overflow-hidden mb-3">
                        @if (!string.IsNullOrEmpty(cat.Image))
                        {
                            <img src="@cat.Image"
                                 alt="@cat.Name"
                                 class="w-full h-full object-cover rounded-full group-hover:scale-110 transition-transform duration-300"
                                 loading="lazy" />
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center bg-white text-primary rounded-full border border-gray-100">
                                <i data-lucide="package" class="w-8 h-8"></i>
                            </div>
                        }
                    </div>
                    <h3 class="text-xs sm:text-sm font-medium text-gray-700 group-hover:text-primary transition-colors line-clamp-2 px-1">@cat.Name</h3>
                </a>
            }
        </div>
    </section>
}

@* ===== SẢN PHẨM NỔI BẬT ===== *@
@if (Model.FeaturedProducts.Count > 0)
{
    <section class="bg-white py-16">
        <div class="max-w-7xl mx-auto px-4">
            <div class="flex items-center justify-between mb-12">
                <div>
                    <h2 class="text-3xl font-bold text-gray-900">Sản phẩm nổi bật</h2>
                    <p class="text-gray-500 mt-2">Được lựa chọn nhiều nhất</p>
                </div>
                <a href="/san-pham" class="text-primary hover:underline font-medium flex items-center gap-1">
                    Xem tất cả
                    <i data-lucide="arrow-right" class="w-4 h-4"></i>
                </a>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                @foreach (var product in Model.FeaturedProducts)
                {
                    <partial name="_ProductCard" model="product" />
                }
            </div>
        </div>
    </section>
}

@* ===== BÀI VIẾT MỚI NHẤT ===== *@
@if (Model.LatestPosts.Count > 0)
{
    <section class="max-w-7xl mx-auto px-4 py-16">
        <div class="flex items-center justify-between mb-12">
            <div>
                <h2 class="text-3xl font-bold text-gray-900">Kiến thức mới</h2>
                <p class="text-gray-500 mt-2">Bài viết & hướng dẫn kỹ thuật</p>
            </div>
            <a href="/kien-thuc" class="text-primary hover:underline font-medium flex items-center gap-1">
                Xem tất cả
                <i data-lucide="arrow-right" class="w-4 h-4"></i>
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var post in Model.LatestPosts.Take(3))
            {
                <a href="@post.SeoUrl"
                   class="group bg-white rounded-xl shadow-sm hover:shadow-lg transition overflow-hidden">
                    @if (!string.IsNullOrEmpty(post.Image))
                    {
                        <div class="aspect-[16/9] overflow-hidden">
                            <img src="@post.Image"
                                 alt="@post.Title"
                                 class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                                 loading="lazy" />
                        </div>
                    }
                    <div class="p-5">
                        <h3 class="font-semibold text-gray-800 group-hover:text-primary transition line-clamp-2 mb-2">
                            @post.Title
                        </h3>
                        @if (!string.IsNullOrEmpty(post.Excerpt))
                        {
                            <p class="text-sm text-gray-500 line-clamp-2">@post.Excerpt</p>
                        }
                        <div class="flex items-center gap-4 mt-3 text-xs text-gray-400">
                            <span class="flex items-center gap-1">
                                <i data-lucide="user" class="w-3 h-3"></i> @post.Author
                            </span>
                            @if (!string.IsNullOrEmpty(post.ReadTime))
                            {
                                <span class="flex items-center gap-1">
                                    <i data-lucide="clock" class="w-3 h-3"></i> @post.ReadTime
                                </span>
                            }
                        </div>
                    </div>
                </a>
            }
        </div>
    </section>
}

@* ===== ABOUT SECTION (dynamic from settings) ===== *@
@if (!string.IsNullOrEmpty(Model.Settings.AboutTitle) || !string.IsNullOrEmpty(Model.Settings.AboutContent))
{
    <section class="bg-gray-50 py-16">
        <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
            @if (!string.IsNullOrEmpty(Model.Settings.AboutImage))
            {
                <img src="@Model.Settings.AboutImage" alt="@Model.Settings.AboutTitle"
                     class="w-full rounded-2xl shadow-lg object-cover" loading="lazy" />
            }
            <div>
                @if (!string.IsNullOrEmpty(Model.Settings.AboutTitle))
                {
                    <h2 class="text-3xl font-bold text-gray-900 mb-4">@Model.Settings.AboutTitle</h2>
                }
                @if (!string.IsNullOrEmpty(Model.Settings.AboutContent))
                {
                    <div class="prose max-w-none text-gray-700">@Html.Raw(Model.Settings.AboutContent)</div>
                }
            </div>
        </div>
    </section>
}

@* ===== JSON-LD: Organization (SEO structured data) ===== *@
@section StructuredData {
    @{
        var jsonLd = new Dictionary<string, object>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "Organization",
            ["name"] = Model.Settings.CompanyName ?? "",
            ["url"] = $"{Context.Request.Scheme}://{Context.Request.Host}"
        };
        if (!string.IsNullOrEmpty(Model.Settings.Logo)) jsonLd["logo"] = Model.Settings.Logo;
        if (!string.IsNullOrEmpty(Model.Settings.Phone)) jsonLd["telephone"] = Model.Settings.Phone;
        if (!string.IsNullOrEmpty(Model.Settings.Email)) jsonLd["email"] = Model.Settings.Email;
        var sameAs = new List<string>();
        if (!string.IsNullOrEmpty(Model.Settings.Facebook)) sameAs.Add(Model.Settings.Facebook);
        if (!string.IsNullOrEmpty(Model.Settings.Youtube)) sameAs.Add(Model.Settings.Youtube);
        if (sameAs.Count > 0) jsonLd["sameAs"] = sameAs;
    }
    <script type="application/ld+json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(jsonLd))</script>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const swiper = new Swiper('.hero-swiper', {
                loop: true,
                speed: 800,
                autoplay: {
                    delay: 10000, // 10 giây
                    disableOnInteraction: false,
                },
                pagination: {
                    el: '.swiper-pagination',
                    clickable: true,
                },
                navigation: {
                    nextEl: '.swiper-button-next',
                    prevEl: '.swiper-button-prev',
                },
                // Mặc định là trượt ngang (slide)
                grabCursor: true,
                watchSlidesProgress: true,
            });
        });
    </script>
}
