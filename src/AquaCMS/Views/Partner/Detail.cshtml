@model Partner
@*
    Chi tiết đối tác (/doi-tac/{slug}).
*@

<div class="max-w-4xl mx-auto px-4 py-8">
    @* Breadcrumb *@
    <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center space-x-2 text-sm text-gray-500">
            <li><a href="/" class="hover:text-primary transition">Trang chủ</a></li>
            <li><span class="mx-1">/</span></li>
            <li><a href="/doi-tac" class="hover:text-primary transition">Đối tác</a></li>
            <li><span class="mx-1">/</span></li>
            <li class="text-gray-800 font-medium truncate max-w-[200px]">@Model.Name</li>
        </ol>
    </nav>

    <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
        @* Header *@
        <div class="p-6 lg:p-10">
            <div class="flex flex-col md:flex-row gap-8">
                @if (!string.IsNullOrEmpty(Model.Image))
                {
                    <div class="md:w-1/3 shrink-0">
                        <img src="@Model.Image" alt="@Model.Name"
                             class="w-full rounded-xl object-cover aspect-square" />
                    </div>
                }
                <div class="flex-1">
                    @if (Model.PartnerCategory != null)
                    {
                        <span class="text-sm text-primary font-medium uppercase">@Model.PartnerCategory.Name</span>
                    }
                    <h1 class="text-3xl font-bold text-gray-900 mt-1 mb-4">@Model.Name</h1>

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <p class="text-gray-600 mb-6">@Model.Description</p>
                    }

                    @* Info grid *@
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                        @if (!string.IsNullOrEmpty(Model.Location))
                        {
                            <div class="flex items-center gap-2 text-gray-600">
                                <i data-lucide="map-pin" class="w-4 h-4 text-gray-400"></i>
                                <span>@Model.Location</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Since))
                        {
                            <div class="flex items-center gap-2 text-gray-600">
                                <i data-lucide="calendar" class="w-4 h-4 text-gray-400"></i>
                                <span>Hợp tác từ: @Model.Since</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.ContactEmail))
                        {
                            <div class="flex items-center gap-2 text-gray-600">
                                <i data-lucide="mail" class="w-4 h-4 text-gray-400"></i>
                                <a href="mailto:@Model.ContactEmail" class="text-primary hover:underline">@Model.ContactEmail</a>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.ContactPhone))
                        {
                            <div class="flex items-center gap-2 text-gray-600">
                                <i data-lucide="phone" class="w-4 h-4 text-gray-400"></i>
                                <a href="tel:@Model.ContactPhone" class="text-primary hover:underline">@Model.ContactPhone</a>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Website))
                        {
                            <div class="flex items-center gap-2 text-gray-600">
                                <i data-lucide="globe" class="w-4 h-4 text-gray-400"></i>
                                <a href="@Model.Website" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">
                                    Website
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Detailed description (HTML) *@
        @if (!string.IsNullOrEmpty(Model.DetailedDescription))
        {
            <div class="border-t px-6 lg:px-10 py-8">
                <h2 class="text-xl font-bold text-gray-900 mb-4">Giới thiệu chi tiết</h2>
                <div class="prose max-w-none">
                    @Html.Raw(Model.DetailedDescription)
                </div>
            </div>
        }
    </div>
</div>
