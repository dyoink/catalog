{
  "name": "aquacms-tailwind",
  "version": "1.0.0",
  "private": true,
  "description": "Tailwind CSS build for AquaCMS production",
  "scripts": {
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./wwwroot/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/tailwind.css -o ./wwwroot/css/tailwind.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.13",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/forms": "^0.5.9"
  }
}
