@model List<KnowledgeCategory>
@{ ViewData["Title"] = "Danh mục kiến thức"; }

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Danh mục kiến thức</h1>
            <p class="text-gray-500 mt-1">@Model.Count danh mục</p>
        </div>
        <a href="/admin/knowledgecategories/create" class="inline-flex items-center gap-2 bg-primary text-white px-5 py-2.5 rounded-lg font-medium hover:opacity-90">
            <i data-lucide="plus" class="w-4 h-4"></i> Thêm danh mục
        </a>
    </div>

    @if (TempData["Success"] != null) { <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg">@TempData["Success"]</div> }
    @if (TempData["Error"] != null) { <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg">@TempData["Error"]</div> }

    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
                <tr><th class="px-4 py-3 text-left">Tên</th><th class="px-4 py-3 text-left">Slug</th><th class="px-4 py-3 text-center">Bài viết</th><th class="px-4 py-3 text-right">Thao tác</th></tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var cat in Model)
                {
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3 font-medium">@cat.Name</td>
                        <td class="px-4 py-3 text-gray-400 text-xs font-mono">@cat.Slug</td>
                        <td class="px-4 py-3 text-center"><span class="px-2 py-1 bg-blue-50 text-blue-600 rounded-full text-xs">@cat.Posts.Count</span></td>
                        <td class="px-4 py-3 text-right">
                            <a href="/admin/knowledgecategories/edit/@cat.Id" class="p-1.5 text-gray-400 hover:text-primary inline-block"><i data-lucide="pencil" class="w-4 h-4"></i></a>
                            <form method="post" action="/admin/knowledgecategories/delete/@cat.Id" class="inline" onsubmit="return confirm('Xóa danh mục này?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="p-1.5 text-gray-400 hover:text-red-500"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (Model.Count == 0) { <div class="text-center py-12 text-gray-400"><i data-lucide="folder-plus" class="w-12 h-12 mx-auto mb-3 opacity-50"></i><p>Chưa có danh mục</p></div> }
    </div>
</div>
@section Scripts { <script>lucide.createIcons();</script> }
