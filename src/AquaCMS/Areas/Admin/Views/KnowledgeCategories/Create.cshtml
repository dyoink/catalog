@model KnowledgeCategory
@{
    ViewData["Title"] ??= "Danh mục kiến thức";
    var isEdit = Model.Id != Guid.Empty;
}

<div class="max-w-2xl">
    <div class="flex items-center gap-3 mb-6">
        <a href="/admin/knowledgecategories" class="p-2 text-gray-400 hover:text-gray-600 rounded-lg"><i data-lucide="arrow-left" class="w-5 h-5"></i></a>
        <h1 class="text-2xl font-bold text-gray-900">@ViewData["Title"]</h1>
    </div>

    @if (TempData["Error"] != null) { <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4">@TempData["Error"]</div> }

    <form method="post" action="@(isEdit ? $"/admin/knowledgecategories/edit/{Model.Id}" : "/admin/knowledgecategories/create")" class="bg-white rounded-xl shadow-sm p-6 space-y-5">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div>
            <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">Tên danh mục</label>
            <input asp-for="Name" required class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50" />
        </div>
        <div>
            <label asp-for="Slug" class="block text-sm font-medium text-gray-700 mb-1">Slug (để trống để tự sinh)</label>
            <input asp-for="Slug" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50" />
        </div>
        <div>
            <label asp-for="SortOrder" class="block text-sm font-medium text-gray-700 mb-1">Thứ tự</label>
            <input asp-for="SortOrder" type="number" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50" />
        </div>
        <button type="submit" class="bg-primary text-white px-6 py-2.5 rounded-lg font-medium hover:opacity-90">@(isEdit ? "Cập nhật" : "Thêm")</button>
    </form>
</div>
@section Scripts { <script>lucide.createIcons();</script> }
