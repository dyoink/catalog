@model Partner
@{
    var isEdit = Model.Id != Guid.Empty;
    ViewData["Title"] = isEdit ? $"Sửa: {Model.Name}" : "Thêm đối tác";
    var categories = ViewData["Categories"] as List<PartnerCategory> ?? new();
}

<div class="max-w-4xl space-y-6">
    <div class="flex items-center gap-4">
        <a href="/admin/partners" class="p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition">
            <i data-lucide="arrow-left" class="w-5 h-5"></i>
        </a>
        <h1 class="text-2xl font-bold text-gray-900">@ViewData["Title"]</h1>
    </div>

    <form method="post"
          action="@(isEdit ? $"/admin/partners/edit/{Model.Id}" : "/admin/partners/create")"
          enctype="multipart/form-data"
          class="space-y-6">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        @* Thông tin cơ bản *@
        <div class="bg-white rounded-xl shadow-sm p-6 space-y-5">
            <h2 class="font-bold text-gray-800 text-lg border-b pb-3">Thông tin đối tác</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div class="md:col-span-2">
                    <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">
                        Tên đối tác <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="Name" required
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary" />
                </div>

                <div>
                    <label asp-for="Slug" class="block text-sm font-medium text-gray-700 mb-1">Slug (URL)</label>
                    <input asp-for="Slug"
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                           placeholder="Tự động tạo từ tên" />
                </div>

                <div>
                    <label asp-for="PartnerCategoryId" class="block text-sm font-medium text-gray-700 mb-1">Danh mục</label>
                    <select asp-for="PartnerCategoryId"
                            class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50">
                        <option value="">— Không có —</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Id" selected="@(Model.PartnerCategoryId == cat.Id)">@cat.Name</option>
                        }
                    </select>
                </div>

                <div>
                    <label asp-for="Location" class="block text-sm font-medium text-gray-700 mb-1">Địa điểm</label>
                    <input asp-for="Location"
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                           placeholder="VD: Cà Mau" />
                </div>

                <div>
                    <label asp-for="Since" class="block text-sm font-medium text-gray-700 mb-1">Năm hợp tác</label>
                    <input asp-for="Since"
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                           placeholder="VD: 2022" />
                </div>

                <div>
                    <label asp-for="SortOrder" class="block text-sm font-medium text-gray-700 mb-1">Thứ tự</label>
                    <input asp-for="SortOrder" type="number"
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50" />
                </div>

                <div class="flex items-center gap-2 pt-6">
                    <input asp-for="IsActive" type="checkbox" class="rounded text-primary focus:ring-primary" />
                    <label asp-for="IsActive" class="text-sm text-gray-700">Hiển thị</label>
                </div>
            </div>

            <div>
                <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1">Mô tả ngắn</label>
                <textarea asp-for="Description" rows="2"
                          class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"></textarea>
            </div>
        </div>

        @* Mô tả chi tiết (TinyMCE) *@
        <div class="bg-white rounded-xl shadow-sm p-6">
            <label class="block text-sm font-medium text-gray-700 mb-3">Mô tả chi tiết (HTML)</label>
            <textarea asp-for="DetailedDescription" id="editor-partner" class="rich-editor w-full hidden">@Model.DetailedDescription</textarea>
        </div>

        @* Liên hệ *@
        <div class="bg-white rounded-xl shadow-sm p-6 space-y-5">
            <h2 class="font-bold text-gray-800 text-lg border-b pb-3">Thông tin liên hệ</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                    <label asp-for="ContactEmail" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <input asp-for="ContactEmail" type="email"
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50" />
                </div>
                <div>
                    <label asp-for="ContactPhone" class="block text-sm font-medium text-gray-700 mb-1">Số điện thoại</label>
                    <input asp-for="ContactPhone"
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50" />
                </div>
                <div>
                    <label asp-for="Website" class="block text-sm font-medium text-gray-700 mb-1">Website</label>
                    <input asp-for="Website" type="url"
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                           placeholder="https://..." />
                </div>
                <div>
                    <label asp-for="Image" class="block text-sm font-medium text-gray-700 mb-1">URL ảnh / Logo</label>
                    <input asp-for="Image"
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                           placeholder="https://... hoặc /uploads/..." />
                    @if (!string.IsNullOrEmpty(Model.Image))
                    {
                        <img id="pn-preview" src="@Model.Image" alt="Preview" class="mt-2 w-20 h-20 rounded-lg object-cover" />
                    }
                    else
                    {
                        <img id="pn-preview" src="" alt="Preview" class="mt-2 w-20 h-20 rounded-lg object-cover hidden" />
                    }
                    <label class="block text-xs text-gray-500 mt-2">Hoặc upload trực tiếp:</label>
                    <input type="file" name="imageFile" accept="image/*" data-preview="#pn-preview" data-crop="1:1"
                           class="mt-1 block w-full text-sm text-gray-600 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-primary/10 file:text-primary hover:file:bg-primary/20" />
                </div>
            </div>
        </div>

        @* Submit *@
        <div class="flex items-center gap-3">
            <button type="submit"
                    class="bg-primary text-white px-8 py-3 rounded-lg font-semibold hover:opacity-90 transition shadow flex items-center gap-2">
                <i data-lucide="save" class="w-5 h-5"></i>
                @(isEdit ? "Cập nhật" : "Thêm đối tác")
            </button>
            <a href="/admin/partners" class="px-6 py-3 text-gray-500 hover:text-gray-700 transition">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        lucide.createIcons();
        // Quill auto-initializes via _AdminLayout.cshtml (rich-editor class)
    </script>
}
