@model PaginatedList<Partner>
@{
    ViewData["Title"] = "Quản lý đối tác";
    var categories = ViewData["Categories"] as List<PartnerCategory> ?? new();
}

<div class="space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Quản lý đối tác</h1>
            <p class="text-gray-500 mt-1">@Model.TotalCount đối tác</p>
        </div>
        <a href="/admin/partners/create"
           class="inline-flex items-center gap-2 bg-primary text-white px-5 py-2.5 rounded-lg font-medium hover:opacity-90 transition">
            <i data-lucide="plus" class="w-4 h-4"></i> Thêm đối tác
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg flex items-center gap-2">
            <i data-lucide="check-circle" class="w-5 h-5"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg flex items-center gap-2">
            <i data-lucide="alert-circle" class="w-5 h-5"></i> @TempData["Error"]
        </div>
    }

    <form method="get" class="bg-white rounded-xl shadow-sm p-4 flex flex-col sm:flex-row gap-3">
        <div class="relative flex-1">
            <input type="text" name="search" value="@ViewBag.Search"
                   placeholder="Tìm theo tên đối tác..."
                   class="w-full pl-10 pr-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary" />
            <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400"></i>
        </div>
        <button type="submit" class="px-5 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-200 transition">
            Tìm kiếm
        </button>
    </form>

    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
                    <tr>
                        <th class="px-4 py-3 text-left">Đối tác</th>
                        <th class="px-4 py-3 text-left hidden md:table-cell">Danh mục</th>
                        <th class="px-4 py-3 text-left hidden lg:table-cell">Địa điểm</th>
                        <th class="px-4 py-3 text-center">Trạng thái</th>
                        <th class="px-4 py-3 text-center hidden sm:table-cell">Thứ tự</th>
                        <th class="px-4 py-3 text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var partner in Model.Items)
                    {
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-4 py-3">
                                <div class="flex items-center gap-3">
                                    @if (!string.IsNullOrEmpty(partner.Image))
                                    {
                                        <img src="@partner.Image" alt="" class="w-10 h-10 rounded-lg object-cover" />
                                    }
                                    else
                                    {
                                        <div class="w-10 h-10 bg-gray-100 rounded-lg flex items-center justify-center">
                                            <i data-lucide="building" class="w-4 h-4 text-gray-300"></i>
                                        </div>
                                    }
                                    <div>
                                        <a href="/admin/partners/edit/@partner.Id" class="font-medium text-gray-800 hover:text-primary">
                                            @partner.Name
                                        </a>
                                        @if (!string.IsNullOrEmpty(partner.ContactPhone))
                                        {
                                            <p class="text-xs text-gray-400">@partner.ContactPhone</p>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td class="px-4 py-3 text-gray-500 hidden md:table-cell">
                                @(partner.PartnerCategory?.Name ?? "—")
                            </td>
                            <td class="px-4 py-3 text-gray-500 hidden lg:table-cell">
                                @(partner.Location ?? "—")
                            </td>
                            <td class="px-4 py-3 text-center">
                                @if (partner.IsActive)
                                {
                                    <span class="px-2 py-1 bg-green-100 text-green-600 rounded-full text-xs font-medium">Hiển thị</span>
                                }
                                else
                                {
                                    <span class="px-2 py-1 bg-gray-100 text-gray-500 rounded-full text-xs font-medium">Ẩn</span>
                                }
                            </td>
                            <td class="px-4 py-3 text-center text-gray-500 hidden sm:table-cell">@partner.SortOrder</td>
                            <td class="px-4 py-3 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="@partner.SeoUrl" target="_blank"
                                       class="p-1.5 text-gray-400 hover:text-primary rounded transition" title="Xem">
                                        <i data-lucide="external-link" class="w-4 h-4"></i>
                                    </a>
                                    <a href="/admin/partners/edit/@partner.Id"
                                       class="p-1.5 text-gray-400 hover:text-primary rounded transition" title="Sửa">
                                        <i data-lucide="pencil" class="w-4 h-4"></i>
                                    </a>
                                    <form method="post" action="/admin/partners/delete/@partner.Id"
                                          onsubmit="return confirm('Xóa đối tác này?');" class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="p-1.5 text-gray-400 hover:text-red-500 rounded transition" title="Xóa">
                                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalCount == 0)
        {
            <div class="text-center py-12 text-gray-400">
                <i data-lucide="building" class="w-12 h-12 mx-auto mb-3 opacity-50"></i>
                <p>Chưa có đối tác nào</p>
            </div>
        }

        @if (Model.TotalPages > 1)
        {
            <div class="border-t px-4 py-3 flex justify-center">
                <div class="flex items-center space-x-1">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <a href="?page=@i&search=@ViewBag.Search"
                           class="px-3 py-1.5 rounded text-sm @(i == Model.PageIndex ? "bg-primary text-white" : "text-gray-600 hover:bg-gray-100")">@i</a>
                    }
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>lucide.createIcons();</script>
}
