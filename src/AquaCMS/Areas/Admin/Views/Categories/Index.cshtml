@model List<Category>
@{
    ViewData["Title"] = "Quản lý danh mục";
}

<div class="space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Quản lý danh mục sản phẩm</h1>
            <p class="text-gray-500 mt-1">@Model.Count danh mục</p>
        </div>
        <a href="/admin/categories/create"
           class="inline-flex items-center gap-2 bg-primary text-white px-5 py-2.5 rounded-lg font-medium hover:opacity-90 transition">
            <i data-lucide="plus" class="w-4 h-4"></i> Thêm danh mục
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg flex items-center gap-2">
            <i data-lucide="check-circle" class="w-5 h-5"></i> @TempData["Success"]
        </div>
    }

    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
                    <tr>
                        <th class="px-4 py-3 text-left">Danh mục</th>
                        <th class="px-4 py-3 text-left hidden sm:table-cell">Slug</th>
                        <th class="px-4 py-3 text-center">Số sản phẩm</th>
                        <th class="px-4 py-3 text-center hidden sm:table-cell">Thứ tự</th>
                        <th class="px-4 py-3 text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var cat in Model)
                    {
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-4 py-3">
                                <div class="flex items-center gap-3">
                                    @if (!string.IsNullOrEmpty(cat.Image))
                                    {
                                        <img src="@cat.Image" alt="" class="w-8 h-8 rounded object-cover" />
                                    }
                                    else
                                    {
                                        <div class="w-8 h-8 bg-gray-100 rounded flex items-center justify-center">
                                            <i data-lucide="folder" class="w-4 h-4 text-gray-300"></i>
                                        </div>
                                    }
                                    <span class="font-medium text-gray-800">@cat.Name</span>
                                </div>
                            </td>
                            <td class="px-4 py-3 text-gray-400 text-xs font-mono hidden sm:table-cell">@cat.Slug</td>
                            <td class="px-4 py-3 text-center">
                                <span class="px-2 py-1 bg-blue-50 text-blue-600 rounded-full text-xs font-medium">
                                    @cat.Products.Count sản phẩm
                                </span>
                            </td>
                            <td class="px-4 py-3 text-center text-gray-500 hidden sm:table-cell">@cat.SortOrder</td>
                            <td class="px-4 py-3 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="/danh-muc/@cat.Slug" target="_blank"
                                       class="p-1.5 text-gray-400 hover:text-primary rounded transition" title="Xem">
                                        <i data-lucide="external-link" class="w-4 h-4"></i>
                                    </a>
                                    <a href="/admin/categories/edit/@cat.Id"
                                       class="p-1.5 text-gray-400 hover:text-primary rounded transition" title="Sửa">
                                        <i data-lucide="pencil" class="w-4 h-4"></i>
                                    </a>
                                    <form method="post" action="/admin/categories/delete/@cat.Id"
                                          onsubmit="return confirm('Xóa danh mục này? Sản phẩm bên trong sẽ bị mất danh mục.');" class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="p-1.5 text-gray-400 hover:text-red-500 rounded transition" title="Xóa">
                                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.Count == 0)
        {
            <div class="text-center py-12 text-gray-400">
                <i data-lucide="folder-plus" class="w-12 h-12 mx-auto mb-3 opacity-50"></i>
                <p>Chưa có danh mục nào</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>lucide.createIcons();</script>
}
