@model User
@{
    ViewData["Title"] = "Thêm người dùng";
}

<div class="max-w-2xl space-y-6">
    <div class="flex items-center gap-4">
        <a href="/admin/users" class="p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition">
            <i data-lucide="arrow-left" class="w-5 h-5"></i>
        </a>
        <h1 class="text-2xl font-bold text-gray-900">Thêm người dùng</h1>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg flex items-center gap-2">
            <i data-lucide="alert-circle" class="w-5 h-5"></i> @TempData["Error"]
        </div>
    }

    <form method="post" action="/admin/users/create" class="space-y-6">
        @Html.AntiForgeryToken()

        <div class="bg-white rounded-xl shadow-sm p-6 space-y-5">
            <h2 class="font-bold text-gray-800 text-lg border-b pb-3">Thông tin tài khoản</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div class="md:col-span-2">
                    <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">
                        Họ tên <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="Name" required
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary" />
                </div>

                <div>
                    <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1">
                        Email <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="Email" type="email" required
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">
                        Mật khẩu <span class="text-red-500">*</span>
                    </label>
                    <input type="password" name="password" required minlength="8"
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                           placeholder="Tối thiểu 8 ký tự" />
                </div>

                <div>
                    <label asp-for="Role" class="block text-sm font-medium text-gray-700 mb-1">Vai trò</label>
                    <select asp-for="Role"
                            class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50">
                        @if (User.IsInRole("SUPER_ADMIN"))
                        {
                            <option value="SUPER_ADMIN">Super Admin</option>
                            <option value="MANAGER">Manager</option>
                        }
                        <option value="EDITOR" selected>Editor</option>
                        <option value="SALE">Sale</option>
                    </select>
                </div>

                <div>
                    <label asp-for="Avatar" class="block text-sm font-medium text-gray-700 mb-1">URL Avatar</label>
                    <input asp-for="Avatar" type="url"
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                           placeholder="https://..." />
                </div>
            </div>
        </div>

        <div class="flex items-center gap-3">
            <button type="submit"
                    class="bg-primary text-white px-8 py-3 rounded-lg font-semibold hover:opacity-90 transition shadow flex items-center gap-2">
                <i data-lucide="user-plus" class="w-5 h-5"></i> Tạo tài khoản
            </button>
            <a href="/admin/users" class="px-6 py-3 text-gray-500 hover:text-gray-700 transition">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>lucide.createIcons();</script>
}
