@model List<User>
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Quản lý người dùng</h1>
            <p class="text-gray-500 mt-1">@Model.Count tài khoản</p>
        </div>
        <a href="/admin/users/create"
           class="inline-flex items-center gap-2 bg-primary text-white px-5 py-2.5 rounded-lg font-medium hover:opacity-90 transition">
            <i data-lucide="plus" class="w-4 h-4"></i> Thêm người dùng
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg flex items-center gap-2">
            <i data-lucide="check-circle" class="w-5 h-5"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg flex items-center gap-2">
            <i data-lucide="alert-circle" class="w-5 h-5"></i> @TempData["Error"]
        </div>
    }

    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
                    <tr>
                        <th class="px-4 py-3 text-left">Người dùng</th>
                        <th class="px-4 py-3 text-left hidden sm:table-cell">Email</th>
                        <th class="px-4 py-3 text-center">Vai trò</th>
                        <th class="px-4 py-3 text-center">Trạng thái</th>
                        <th class="px-4 py-3 text-left hidden lg:table-cell">Đăng nhập cuối</th>
                        <th class="px-4 py-3 text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var user in Model)
                    {
                        var isSelf = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == user.Id.ToString();
                        <tr class="hover:bg-gray-50 transition @(isSelf ? "bg-blue-50/30" : "")">
                            <td class="px-4 py-3">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-full flex items-center justify-center text-white font-bold text-sm
                                        @(user.Role == UserRole.SUPER_ADMIN ? "bg-red-500" :
                                          user.Role == UserRole.MANAGER ? "bg-purple-500" :
                                          user.Role == UserRole.EDITOR ? "bg-green-500" : "bg-gray-400")">
                                        @user.Name[..1].ToUpper()
                                    </div>
                                    <div>
                                        <span class="font-medium text-gray-800">@user.Name</span>
                                        @if (isSelf)
                                        {
                                            <span class="text-xs text-primary ml-1">(bạn)</span>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td class="px-4 py-3 text-gray-500 hidden sm:table-cell">@user.Email</td>
                            <td class="px-4 py-3 text-center">
                                @switch (user.Role)
                                {
                                    case UserRole.SUPER_ADMIN:
                                        <span class="px-2 py-1 bg-red-100 text-red-600 rounded-full text-xs font-medium">Super Admin</span>
                                        break;
                                    case UserRole.MANAGER:
                                        <span class="px-2 py-1 bg-purple-100 text-purple-600 rounded-full text-xs font-medium">Manager</span>
                                        break;
                                    case UserRole.EDITOR:
                                        <span class="px-2 py-1 bg-green-100 text-green-600 rounded-full text-xs font-medium">Editor</span>
                                        break;
                                    case UserRole.SALE:
                                        <span class="px-2 py-1 bg-blue-100 text-blue-600 rounded-full text-xs font-medium">Sale</span>
                                        break;
                                }
                            </td>
                            <td class="px-4 py-3 text-center">
                                @if (user.IsActive)
                                {
                                    <span class="inline-flex items-center gap-1 px-2 py-1 bg-green-100 text-green-600 rounded-full text-xs font-medium">
                                        <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span> Hoạt động
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1 px-2 py-1 bg-gray-100 text-gray-500 rounded-full text-xs font-medium">
                                        <span class="w-1.5 h-1.5 bg-gray-400 rounded-full"></span> Vô hiệu
                                    </span>
                                }
                            </td>
                            <td class="px-4 py-3 text-gray-400 text-sm hidden lg:table-cell">
                                @(user.LastLoginAt?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa đăng nhập")
                            </td>
                            <td class="px-4 py-3 text-right">
                                <div class="flex items-center justify-end gap-1">
                                    @if (!isSelf)
                                    {
                                        <form method="post" action="/admin/users/toggleactive/@user.Id" class="inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="p-1.5 rounded transition @(user.IsActive ? "text-gray-400 hover:text-amber-500" : "text-gray-400 hover:text-green-500")"
                                                    title="@(user.IsActive ? "Vô hiệu hóa" : "Kích hoạt")">
                                                <i data-lucide="@(user.IsActive ? "user-x" : "user-check")" class="w-4 h-4"></i>
                                            </button>
                                        </form>

                                        @if (User.IsInRole("SUPER_ADMIN"))
                                        {
                                            <form method="post" action="/admin/users/delete/@user.Id"
                                                  onsubmit="return confirm('Xóa tài khoản @user.Name?');" class="inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="p-1.5 text-gray-400 hover:text-red-500 rounded transition" title="Xóa">
                                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                                </button>
                                            </form>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>lucide.createIcons();</script>
}
