@inject AquaCMS.Services.Interfaces.ISettingsService SettingsService
@{
    var siteSettings = await SettingsService.GetSettingsAsync();
    var primaryColor = !string.IsNullOrEmpty(siteSettings?.PrimaryColor) ? siteSettings.PrimaryColor : "#2563eb";
}
@*
    Layout quản trị — sidebar navigation + main content area.
    Chỉ dành cho admin (đã authorize ở controller).
*@
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin AquaCMS</title>
    <meta name="robots" content="noindex, nofollow" />

    <script>
        (function () {
            try {
                var t = localStorage.getItem('aquacms-theme');
                if (t === 'dark' || (!t && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                    document.documentElement.classList.add('dark');
                }
            } catch (e) { /* ignore */ }
        })();
    </script>

    <environment include="Production">
        <link href="~/css/tailwind.css" rel="stylesheet" asp-append-version="true" />
    </environment>
    <environment include="Development,Staging">
        <script src="https://cdn.tailwindcss.com"></script>
        <script>
            tailwind.config = {
                darkMode: 'class',
                theme: {
                    extend: {
                        colors: { primary: '#55B3D9' }
                    }
                }
            }
        </script>
    </environment>

    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@8.0.7/dist/browser/signalr.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>

    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* Global Dark Mode Overrides */
        .dark body { background-color: #030712 !important; color: #e5e7eb !important; }
        
        /* Ép các card trắng sang màu tối */
        .dark .bg-white { background-color: #111827 !important; border-color: #1f2937 !important; }
        
        /* Chỉnh màu chữ */
        .dark .text-gray-900 { color: #f9fafb !important; }
        .dark .text-gray-800 { color: #f3f4f6 !important; }
        .dark .text-gray-700 { color: #e5e7eb !important; }
        .dark .text-gray-600 { color: #d1d5db !important; }
        .dark .text-gray-500 { color: #9ca3af !important; }
        
        /* Bảng (Tables) */
        .dark table { color: #d1d5db !important; }
        .dark thead { background-color: #1f2937 !important; }
        .dark th { color: #f3f4f6 !important; border-color: #374151 !important; }
        .dark td { border-color: #1f2937 !important; }
        .dark tr:hover { background-color: #1f2937 !important; }

        /* Form inputs */
        .dark input, .dark select, .dark textarea { 
            background-color: #1f2937 !important; 
            border-color: #374151 !important; 
            color: #f3f4f6 !important; 
        }
        .dark input::placeholder { color: #6b7280 !important; }

        /* Tiêu đề trang */
        .dark h1, .dark h2, .dark h3, .dark h4 { color: #ffffff !important; }

        /* Phân trang & Nút */
        .dark .pagination-link { background-color: #1f2937 !important; border-color: #374151 !important; color: #d1d5db !important; }
        .dark .pagination-link.active { background-color: #2563eb !important; border-color: #2563eb !important; color: #ffffff !important; }

        /* Các lớp tiện ích gray (thường dùng cho nút phụ, lọc, chat bubble khách) */
        .dark .bg-gray-50 { background-color: #030712 !important; }
        .dark .bg-gray-100 { background-color: #1f2937 !important; color: #d1d5db !important; }
        .dark .bg-gray-200 { background-color: #374151 !important; color: #e5e7eb !important; }
        
        .dark .hover\:bg-gray-50:hover { background-color: #111827 !important; }
        .dark .hover\:bg-gray-100:hover { background-color: #1f2937 !important; }
        .dark .hover\:bg-gray-200:hover { background-color: #374151 !important; }

        .dark .border-gray-100 { border-color: #1f2937 !important; }
        .dark .border-gray-200 { border-color: #374151 !important; }

        /* Ép màu chữ cho các nút gray-100/200 */
        .dark .text-gray-700, .dark .text-gray-800 { color: #d1d5db !important; }
    </style>
    @await RenderSectionAsync("Head", required: false)
</head>
<body class="bg-gray-50 dark:bg-gray-950 dark:text-gray-200 h-screen overflow-hidden transition-colors">
    
    <div class="flex h-full">
        @* ===== SIDEBAR (Cố định hoàn toàn) ===== *@
        <aside id="admin-sidebar"
               class="w-64 bg-white dark:bg-gray-950 text-gray-600 dark:text-gray-300 flex flex-col shrink-0 fixed inset-y-0 left-0 z-50 border-r border-gray-200 dark:border-gray-800
                      transform -translate-x-full md:translate-x-0 md:relative transition-colors transition-transform duration-200">
            
            @* Logo Area *@
            <div class="h-16 flex-none flex items-center px-6 border-b border-white/10 shadow-sm" style="background-color: @primaryColor;">
                <a href="/admin" class="flex items-center space-x-2 text-white font-bold text-lg">
                    <i data-lucide="settings" class="w-6 h-6"></i>
                    <span>Admin Panel</span>
                </a>
            </div>

            @* Navigation (Cuộn độc lập bên trong sidebar nếu menu quá dài) *@
            <nav class="flex-1 py-4 overflow-y-auto overflow-x-hidden scrollbar-thin dark:scrollbar-thumb-gray-700">
                <div class="px-3 space-y-1">
                    <a href="/admin" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white transition">
                        <i data-lucide="layout-dashboard" class="w-5 h-5"></i> Dashboard
                    </a>
                    <a href="/admin/products" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white transition">
                        <i data-lucide="package" class="w-5 h-5"></i> Sản phẩm
                    </a>
                    <a href="/admin/categories" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white transition pl-10">
                        <i data-lucide="folder" class="w-4 h-4"></i> Danh mục SP
                    </a>
                    <a href="/admin/knowledge" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white transition">
                        <i data-lucide="book-open" class="w-5 h-5"></i> Kiến thức
                    </a>
                    <a href="/admin/knowledgecategories" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white transition pl-10">
                        <i data-lucide="folder" class="w-4 h-4"></i> Danh mục KT
                    </a>
                    <a href="/admin/partners" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white transition">
                        <i data-lucide="handshake" class="w-5 h-5"></i> Đối tác
                    </a>
                    <a href="/admin/partnercategories" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white transition pl-10">
                        <i data-lucide="folder" class="w-4 h-4"></i> Danh mục ĐT
                    </a>
                    <a href="/admin/banners" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white transition">
                        <i data-lucide="image" class="w-5 h-5"></i> Banner
                    </a>
                    <a href="/admin/messages" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white transition">
                        <i data-lucide="message-square" class="w-5 h-5"></i> Tin nhắn
                    </a>

                    <div class="border-t border-gray-200 dark:border-gray-800 my-3"></div>

                    @if (User.IsInRole("SUPER_ADMIN") || User.IsInRole("MANAGER"))
                    {
                        <a href="/admin/users" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white transition">
                            <i data-lucide="users" class="w-5 h-5"></i> Người dùng
                        </a>
                        <a href="/admin/activity" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white transition">
                            <i data-lucide="history" class="w-5 h-5"></i> Nhật ký
                        </a>
                    }
                    <a href="/admin/profile" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white transition">
                        <i data-lucide="user-circle" class="w-5 h-5"></i> Hồ sơ
                    </a>
                    @if (User.IsInRole("SUPER_ADMIN"))
                    {
                        <a href="/admin/settings" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white transition">
                            <i data-lucide="sliders-horizontal" class="w-5 h-5"></i> Cài đặt
                        </a>
                    }
                </div>
            </nav>

            @* User Footer (Luôn ghim ở đáy Sidebar) *@
            <div class="flex-none border-t border-gray-200 dark:border-gray-800 p-4 bg-gray-50 dark:bg-gray-950">
                <div class="flex items-center gap-3 mb-3">
                    <div class="w-8 h-8 bg-primary/20 rounded-full flex items-center justify-center text-primary font-bold text-sm">
                        @(User.Identity?.Name?[..1].ToUpper() ?? "A")
                    </div>
                    <div class="text-sm flex-1 min-w-0">
                        <p class="text-gray-900 dark:text-white font-medium truncate">@User.Identity?.Name</p>
                        <p class="text-xs text-gray-500">@User.FindFirst("Role")?.Value</p>
                    </div>
                    <button id="theme-toggle" type="button"
                            class="p-2 rounded-lg bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-500 dark:text-gray-300 transition">
                        <i data-lucide="sun" class="w-4 h-4 hidden dark:inline"></i>
                        <i data-lucide="moon" class="w-4 h-4 inline dark:hidden"></i>
                    </button>
                </div>
                <div class="flex gap-2">
                    <a href="/" class="flex-1 text-center text-xs px-2 py-1.5 rounded border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition">Trang chủ</a>
                    <a href="/dang-xuat" class="flex-1 text-center text-xs px-2 py-1.5 rounded bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 hover:bg-red-100 dark:hover:bg-red-900/40 transition">Đăng xuất</a>
                </div>
            </div>
        </aside>

        @* ===== CONTENT AREA (Phần này sẽ cuộn) ===== *@
        <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
            
            @* Top bar (Mobile only) *@
            <header class="md:hidden flex-none h-16 text-white flex items-center px-4 shadow-md" style="background-color: @primaryColor;">
                <button id="sidebar-toggle" class="p-2 hover:bg-white/10 rounded-lg">
                    <i data-lucide="menu" class="w-6 h-6"></i>
                </button>
                <span class="ml-3 font-bold">Admin Panel</span>
            </header>

            @* Scrollable Main Content *@
            <main class="flex-1 overflow-y-auto p-4 md:p-8 dark:text-gray-200">
                <div class="max-w-7xl mx-auto">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    @* Mobile overlay *@
    <div id="sidebar-overlay" class="hidden fixed inset-0 bg-black/50 z-40 md:hidden"></div>

    @* Modals and Scripts ... (giữ nguyên logic cũ) *@
    <div id="crop-modal" class="hidden fixed inset-0 bg-black/70 z-[60] flex items-center justify-center p-4">
        <div class="bg-white dark:bg-gray-900 rounded-xl shadow-2xl max-w-3xl w-full max-h-[90vh] flex flex-col overflow-hidden">
             @* (Nội dung modal giữ nguyên) *@
             <div class="flex items-center justify-between px-5 py-3 border-b dark:border-gray-800">
                <h3 class="font-bold text-gray-800 dark:text-gray-100 flex items-center gap-2"><i data-lucide="crop" class="w-5 h-5 text-primary"></i>Cắt ảnh</h3>
                <button id="crop-close" type="button" class="text-gray-500 hover:text-red-500"><i data-lucide="x" class="w-5 h-5"></i></button>
            </div>
            <div class="flex-1 overflow-auto bg-gray-900 flex items-center justify-center min-h-[300px]"><img id="crop-image" class="max-w-full max-h-[60vh]" /></div>
            <div class="flex flex-wrap items-center justify-between gap-2 px-5 py-3 border-t dark:border-gray-800 bg-gray-50 dark:bg-gray-800">
                <div class="flex gap-1">
                    <button type="button" data-crop-rot="-90" class="p-2 bg-white dark:bg-gray-700 border dark:border-gray-600 rounded"><i data-lucide="rotate-ccw" class="w-4 h-4"></i></button>
                    <button type="button" data-crop-rot="90" class="p-2 bg-white dark:bg-gray-700 border dark:border-gray-600 rounded"><i data-lucide="rotate-cw" class="w-4 h-4"></i></button>
                </div>
                <div class="flex gap-2">
                    <button id="crop-cancel" type="button" class="px-4 py-2 text-sm border dark:border-gray-600 rounded-lg">Bỏ qua</button>
                    <button id="crop-apply" type="button" class="px-4 py-2 text-sm bg-primary text-white rounded-lg inline-flex items-center gap-1.5"><i data-lucide="check" class="w-4 h-4"></i> Áp dụng</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();

        var sidebar = document.getElementById('admin-sidebar');
        var overlay = document.getElementById('sidebar-overlay');
        var toggle  = document.getElementById('sidebar-toggle');

        function openSidebar() { sidebar?.classList.remove('-translate-x-full'); overlay?.classList.remove('hidden'); }
        function closeSidebar() { sidebar?.classList.add('-translate-x-full'); overlay?.classList.add('hidden'); }

        toggle?.addEventListener('click', openSidebar);
        overlay?.addEventListener('click', closeSidebar);

        var currentPath = window.location.pathname;
        document.querySelectorAll('.sidebar-link').forEach(function(link) {
            if (currentPath === link.getAttribute('href') || (link.getAttribute('href') !== '/admin' && currentPath.startsWith(link.getAttribute('href')))) {
                link.classList.add('bg-primary', 'text-white');
                link.classList.remove('text-gray-600', 'dark:text-gray-300');
            }
        });

        // Quill & Cropper Logic (Giữ nguyên như cũ)
        (function () {
            if (typeof Quill === 'undefined') return;
            document.querySelectorAll('textarea.rich-editor').forEach(function (ta) {
                var holder = document.createElement('div');
                holder.style.minHeight = '300px';
                ta.style.display = 'none';
                ta.parentNode.insertBefore(holder, ta.nextSibling);
                var quill = new Quill(holder, { theme: 'snow' });
                if (ta.value) { quill.clipboard.dangerouslyPasteHTML(ta.value); }
                var form = ta.closest('form');
                if (form) { form.addEventListener('submit', function () { ta.value = quill.root.innerHTML; }); }
            });
        })();

        // Dark mode toggle
        (function () {
            var btn = document.getElementById('theme-toggle');
            if (!btn) return;
            btn.addEventListener('click', function () {
                var isDark = document.documentElement.classList.toggle('dark');
                localStorage.setItem('aquacms-theme', isDark ? 'dark' : 'light');
                lucide.createIcons();
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
