@model Banner
@{
    var isEdit = Model.Id != Guid.Empty;
    ViewData["Title"] = isEdit ? $"Sửa banner: {Model.Title}" : "Thêm Banner";
}

<div class="max-w-3xl space-y-6">
    <div class="flex items-center gap-4">
        <a href="/admin/banners" class="p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition">
            <i data-lucide="arrow-left" class="w-5 h-5"></i>
        </a>
        <h1 class="text-2xl font-bold text-gray-900">@ViewData["Title"]</h1>
    </div>

    <form method="post"
          action="@(isEdit ? $"/admin/banners/edit/{Model.Id}" : "/admin/banners/create")"
          enctype="multipart/form-data"
          class="space-y-6">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="bg-white rounded-xl shadow-sm p-6 space-y-5">
            <h2 class="font-bold text-gray-800 text-lg border-b pb-3">Thông tin Banner</h2>

            <div>
                <label asp-for="Title" class="block text-sm font-medium text-gray-700 mb-1">
                    Tiêu đề <span class="text-red-500">*</span>
                </label>
                <input asp-for="Title" required
                       class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary"
                       placeholder="VD: Khuyến mãi mùa hè" />
            </div>

            <div>
                <label asp-for="Subtitle" class="block text-sm font-medium text-gray-700 mb-1">Phụ đề</label>
                <input asp-for="Subtitle"
                       class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                       placeholder="Dòng chữ phụ" />
            </div>

            <div>
                <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1">Mô tả</label>
                <textarea asp-for="Description" rows="2"
                          class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                          placeholder="Nội dung chi tiết banner"></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                    <label asp-for="Image" class="block text-sm font-medium text-gray-700 mb-1">
                        URL ảnh <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="Image"
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                           placeholder="https://... hoặc /uploads/..." />
                    @if (!string.IsNullOrEmpty(Model.Image))
                    {
                        <img id="bn-preview" src="@Model.Image" alt="Preview" class="mt-2 w-full h-24 rounded-lg object-cover" />
                    }
                    else
                    {
                        <img id="bn-preview" src="" alt="Preview" class="mt-2 w-full h-24 rounded-lg object-cover hidden" />
                    }
                    <label class="block text-xs text-gray-500 mt-2">Hoặc upload trực tiếp:</label>
                    <input type="file" name="imageFile" accept="image/*" data-preview="#bn-preview" data-crop="16:9"
                           class="mt-1 block w-full text-sm text-gray-600 file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-primary/10 file:text-primary hover:file:bg-primary/20" />
                </div>
                <div>
                    <label asp-for="LinkUrl" class="block text-sm font-medium text-gray-700 mb-1">Link (khi click)</label>
                    <input asp-for="LinkUrl" type="url"
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                           placeholder="https://..." />
                </div>
                <div>
                    <label asp-for="Color" class="block text-sm font-medium text-gray-700 mb-1">Màu nền</label>
                    <div class="flex items-center gap-2">
                        <input asp-for="Color" type="text"
                               class="flex-1 px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                               placeholder="#55B3D9" />
                        <input type="color" value="@(Model.Color ?? "#55B3D9")"
                               onchange="document.getElementById('Color').value = this.value"
                               class="w-10 h-10 rounded-lg border border-gray-200 cursor-pointer" />
                    </div>
                </div>
                <div>
                    <label asp-for="SortOrder" class="block text-sm font-medium text-gray-700 mb-1">Thứ tự</label>
                    <input asp-for="SortOrder" type="number"
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50" />
                </div>
            </div>

            <div class="flex items-center gap-2 pt-2">
                <input asp-for="IsActive" type="checkbox" class="rounded text-primary focus:ring-primary" />
                <label asp-for="IsActive" class="text-sm text-gray-700">Hiển thị banner</label>
            </div>
        </div>

        <div class="flex items-center gap-3">
            <button type="submit"
                    class="bg-primary text-white px-8 py-3 rounded-lg font-semibold hover:opacity-90 transition shadow flex items-center gap-2">
                <i data-lucide="save" class="w-5 h-5"></i>
                @(isEdit ? "Cập nhật" : "Thêm banner")
            </button>
            <a href="/admin/banners" class="px-6 py-3 text-gray-500 hover:text-gray-700 transition">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>lucide.createIcons();</script>
}
