@model Product
@using System.Text.Json
@*
    Admin: Form thêm/sửa sản phẩm — dùng chung cho Create và Edit.
    Bao gồm: thông tin cơ bản, SEO fields, content blocks editor.
*@
@{
    var isEdit = Model.Id != Guid.Empty;
    ViewData["Title"] = isEdit ? $"Sửa: {Model.Name}" : "Thêm sản phẩm mới";
    var categories = ViewData["Categories"] as List<Category> ?? new();
    
    // Chuẩn bị JSON an toàn
    var initialJson = "[]";
    if (Model.ContentBlocks != null)
    {
        initialJson = JsonSerializer.Serialize(Model.ContentBlocks);
    }
}

<div class="max-w-4xl space-y-6">
    @* Header *@
    <div class="flex items-center gap-4">
        <a href="/admin/products" class="p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition">
            <i data-lucide="arrow-left" class="w-5 h-5"></i>
        </a>
        <h1 class="text-2xl font-bold text-gray-900">@ViewData["Title"]</h1>
    </div>

    <form method="post"
          action="@(isEdit ? $"/admin/products/edit/{Model.Id}" : "/admin/products/create")"
          enctype="multipart/form-data"
          class="space-y-6">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        @* ===== THÔNG TIN CƠ BẢN ===== *@
        <div class="bg-white rounded-xl shadow-sm p-6 space-y-5">
            <h2 class="font-bold text-gray-800 text-lg border-b pb-3">Thông tin cơ bản</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                @* Tên sản phẩm *@
                <div class="md:col-span-2">
                    <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">
                        Tên sản phẩm <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="Name" required
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary"
                           placeholder="VD: Máy sục khí ao tôm 750W" />
                </div>

                @* Slug *@
                <div>
                    <label asp-for="Slug" class="block text-sm font-medium text-gray-700 mb-1">Slug (URL)</label>
                    <input asp-for="Slug"
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                           placeholder="Tự động tạo từ tên" />
                    <p class="text-xs text-gray-400 mt-1">Để trống để tự động tạo từ tên sản phẩm</p>
                </div>

                @* SKU *@
                <div>
                    <label asp-for="Sku" class="block text-sm font-medium text-gray-700 mb-1">Mã SKU</label>
                    <input asp-for="Sku"
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                           placeholder="VD: MAY-SUC-KHI-750" />
                </div>

                @* Danh mục *@
                <div>
                    <label asp-for="CategoryId" class="block text-sm font-medium text-gray-700 mb-1">Danh mục</label>
                    <select asp-for="CategoryId"
                            class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50">
                        <option value="">— Chọn danh mục —</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Id" selected="@(Model.CategoryId == cat.Id)">@cat.Name</option>
                        }
                    </select>
                </div>

                @* Giá *@
                <div>
                    <label asp-for="Price" class="block text-sm font-medium text-gray-700 mb-1">Giá (VNĐ)</label>
                    <input asp-for="Price" type="number" step="1000" min="0"
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                           placeholder="Để trống = Liên hệ báo giá" />
                </div>

                @* Trạng thái *@
                <div>
                    <label asp-for="Status" class="block text-sm font-medium text-gray-700 mb-1">Trạng thái</label>
                    <select asp-for="Status"
                            class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50">
                        <option value="Available" selected="@(Model.Status == ProductStatus.Available)">Hiển thị</option>
                        <option value="Hidden" selected="@(Model.Status == ProductStatus.Hidden)">Ẩn</option>
                        <option value="OutOfStock" selected="@(Model.Status == ProductStatus.OutOfStock)">Hết hàng</option>
                    </select>
                </div>

                @* Nổi bật *@
                <div class="flex items-center gap-6 pt-6">
                    <div class="flex items-center gap-2">
                        <input asp-for="IsFeatured" type="checkbox" class="rounded text-primary focus:ring-primary" />
                        <label asp-for="IsFeatured" class="text-sm text-gray-700">Sản phẩm nổi bật</label>
                    </div>
                    <div class="flex items-center gap-2">
                        <input asp-for="ShowPrice" type="checkbox" class="rounded text-primary focus:ring-primary" />
                        <label asp-for="ShowPrice" class="text-sm text-gray-700">Hiển thị giá</label>
                    </div>
                </div>
            </div>

            @* Mô tả ngắn *@
            <div>
                <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1">Mô tả ngắn</label>
                <textarea asp-for="Description" rows="3"
                          class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                          placeholder="Mô tả tóm tắt sản phẩm (hiện ở trang detail)"></textarea>
            </div>
        </div>

        @* ===== HÌNH ẢNH & VIDEO ===== *@
        <div class="bg-white rounded-xl shadow-sm p-6 space-y-5">
            <h2 class="font-bold text-gray-800 text-lg border-b pb-3">Hình ảnh & Video</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                    <label asp-for="Image" class="block text-sm font-medium text-gray-700 mb-1">URL ảnh đại diện</label>
                    <input asp-for="Image" id="img-url"
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                           placeholder="https://... hoặc /uploads/..." />
                    <img id="img-preview" src="@(Model.Image ?? "")" alt="Preview"
                         class="mt-2 w-32 h-32 rounded-lg object-cover border @(string.IsNullOrEmpty(Model.Image) ? "hidden" : "")" />
                    <label class="block text-xs text-gray-500 mt-2">Hoặc upload trực tiếp (≤ 20MB):</label>
                    <input type="file" name="imageFile" accept="image/*" data-preview="#img-preview" data-crop="1:1"
                           class="mt-1 block w-full text-sm text-gray-600 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-primary/10 file:text-primary hover:file:bg-primary/20" />
                </div>
                <div>
                    <label asp-for="VideoUrl" class="block text-sm font-medium text-gray-700 mb-1">URL video (YouTube)</label>
                    <input asp-for="VideoUrl" type="url"
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                           placeholder="https://youtube.com/..." />
                </div>
            </div>
        </div>

        @* ===== SEO ===== *@
        <div class="bg-white rounded-xl shadow-sm p-6 space-y-5">
            <h2 class="font-bold text-gray-800 text-lg border-b pb-3">SEO</h2>

            <div>
                <label asp-for="MetaTitle" class="block text-sm font-medium text-gray-700 mb-1">Meta Title</label>
                <input asp-for="MetaTitle"
                       class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                       placeholder="Để trống = dùng tên sản phẩm" />
            </div>
            <div>
                <label asp-for="MetaDesc" class="block text-sm font-medium text-gray-700 mb-1">Meta Description</label>
                <textarea asp-for="MetaDesc" rows="2"
                          class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                          placeholder="Để trống = dùng mô tả ngắn"></textarea>
            </div>
        </div>

        @* ===== CONTENT BLOCKS (visual editor) ===== *@
        <div class="bg-white rounded-xl shadow-sm p-6 space-y-5" id="cb-editor-root">
            @* Script block chứa data JSON an toàn *@
            <script id="cb-initial-data" type="application/json">@Html.Raw(initialJson)</script>
            
            <div x-data="contentBlocksEditor(JSON.parse(document.getElementById('cb-initial-data').textContent))">
                <div class="flex items-center justify-between border-b pb-3 mb-5">
                    <h2 class="font-bold text-gray-800 text-lg">Nội dung chi tiết (Content Blocks)</h2>
                </div>

                <div class="space-y-4">
                    <template x-for="(block, idx) in blocks" :key="idx">
                        <div class="cb-block bg-gray-50/50 p-4 rounded-lg border border-gray-100">
                            <div class="flex items-center gap-2 mb-3">
                                <select x-model="block.type" class="text-sm border border-gray-200 rounded px-2 py-1 bg-white">
                                    <option value="heading">Tiêu đề</option>
                                    <option value="paragraph">Đoạn văn</option>
                                    <option value="image">Ảnh</option>
                                    <option value="list">Danh sách</option>
                                    <option value="video">Video</option>
                                </select>
                                <span class="text-xs text-gray-400 font-mono" x-text="'#' + (idx+1)"></span>
                                <div class="ml-auto flex items-center gap-1">
                                    <button type="button" @@click="move(idx,-1)" :disabled="idx===0" class="p-1 text-gray-400 hover:text-gray-700 disabled:opacity-30 transition"><i data-lucide="arrow-up" class="w-4 h-4"></i></button>
                                    <button type="button" @@click="move(idx,1)" :disabled="idx===blocks.length-1" class="p-1 text-gray-400 hover:text-gray-700 disabled:opacity-30 transition"><i data-lucide="arrow-down" class="w-4 h-4"></i></button>
                                    <button type="button" @@click="remove(idx)" class="p-1 text-red-400 hover:text-red-600 transition"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                                </div>
                            </div>
                            
                            <template x-if="block.type==='heading'">
                                <input type="text" x-model="block.content" placeholder="Nhập tiêu đề..." class="w-full text-lg font-bold px-3 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary/30" />
                            </template>
                            
                            <template x-if="block.type==='paragraph'">
                                <textarea x-model="block.content" rows="3" placeholder="Nhập nội dung đoạn văn..." class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/30"></textarea>
                            </template>
                            
                            <template x-if="block.type==='image'">
                                <div class="space-y-2">
                                    <input type="url" x-model="block.url" placeholder="URL ảnh (https://...)" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/30" />
                                    <input type="text" x-model="block.alt" placeholder="Mô tả ảnh (alt)" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/30" />
                                    <div x-show="block.url" class="mt-2">
                                        <img :src="block.url" class="max-h-40 rounded-lg border border-gray-200 object-contain" />
                                    </div>
                                </div>
                            </template>
                            
                            <template x-if="block.type==='list'">
                                <textarea x-model="block.content" rows="4" placeholder="Mỗi dòng một mục..." class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/30 font-mono"></textarea>
                            </template>
                            
                            <template x-if="block.type==='video'">
                                <input type="url" x-model="block.url" placeholder="URL video YouTube..." class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/30" />
                            </template>
                        </div>
                    </template>

                    <div class="pt-6 border-t mt-6">
                        <p class="text-sm font-semibold text-gray-700 mb-4 flex items-center gap-2">
                            <i data-lucide="plus-circle" class="w-4 h-4"></i> Thêm nội dung mới:
                        </p>
                        <div class="flex flex-wrap gap-2">
                            <button type="button" @@click="add('heading')" class="text-sm px-4 py-2.5 bg-white border border-gray-200 rounded-lg hover:bg-gray-50 hover:border-gray-300 transition flex items-center gap-2 shadow-sm">
                                <i data-lucide="heading" class="w-4 h-4 text-primary"></i> Tiêu đề
                            </button>
                            <button type="button" @@click="add('paragraph')" class="text-sm px-4 py-2.5 bg-white border border-gray-200 rounded-lg hover:bg-gray-50 hover:border-gray-300 transition flex items-center gap-2 shadow-sm">
                                <i data-lucide="align-left" class="w-4 h-4 text-primary"></i> Đoạn văn
                            </button>
                            <button type="button" @@click="add('image')" class="text-sm px-4 py-2.5 bg-white border border-gray-200 rounded-lg hover:bg-gray-50 hover:border-gray-300 transition flex items-center gap-2 shadow-sm">
                                <i data-lucide="image" class="w-4 h-4 text-primary"></i> Ảnh
                            </button>
                            <button type="button" @@click="add('list')" class="text-sm px-4 py-2.5 bg-white border border-gray-200 rounded-lg hover:bg-gray-50 hover:border-gray-300 transition flex items-center gap-2 shadow-sm">
                                <i data-lucide="list" class="w-4 h-4 text-primary"></i> Danh sách
                            </button>
                            <button type="button" @@click="add('video')" class="text-sm px-4 py-2.5 bg-white border border-gray-200 rounded-lg hover:bg-gray-50 hover:border-gray-300 transition flex items-center gap-2 shadow-sm">
                                <i data-lucide="video" class="w-4 h-4 text-primary"></i> Video
                            </button>
                        </div>
                    </div>
                </div>

                @* Trường ẩn để submit JSON *@
                <textarea name="contentBlocksJson" :value="submitJson()" class="hidden"></textarea>
            </div>
        </div>

        @* ===== SUBMIT ===== *@
        <div class="flex items-center gap-3 pt-4">
            <button type="submit"
                    class="bg-primary text-white px-10 py-3.5 rounded-xl font-bold hover:opacity-90 transition shadow-lg flex items-center gap-2">
                <i data-lucide="save" class="w-5 h-5"></i>
                @(isEdit ? "Cập nhật thay đổi" : "Thêm sản phẩm ngay")
            </button>
            <a href="/admin/products" class="px-6 py-3 text-gray-500 hover:text-gray-800 transition font-medium">
                Hủy bỏ
            </a>
        </div>
    </form>
</div>

@* Script được đặt trực tiếp để đảm bảo hoạt động khi dùng làm Partial View *@
<script>
    (function() {
        // Khởi tạo icons Lucide
        if (typeof lucide !== 'undefined') lucide.createIcons();

        // Sync image URL input -> preview
        document.getElementById('img-url')?.addEventListener('input', function (e) {
            var preview = document.getElementById('img-preview');
            if (!preview) return;
            if (e.target.value) { 
                preview.src = e.target.value; 
                preview.classList.remove('hidden'); 
            } else { 
                preview.classList.add('hidden'); 
            }
        });

        // Alpine component logic
        window.contentBlocksEditor = function(initialBlocks) {
            return {
                blocks: Array.isArray(initialBlocks) ? initialBlocks : [],
                add(type) {
                    this.blocks.push({ type: type, content: '', url: '', alt: '' });
                    this.refreshIcons();
                },
                remove(idx) {
                    this.blocks.splice(idx, 1);
                },
                move(idx, dir) {
                    let to = idx + dir;
                    if (to < 0 || to >= this.blocks.length) return;
                    let arr = [...this.blocks];
                    [arr[idx], arr[to]] = [arr[to], arr[idx]];
                    this.blocks = arr;
                    this.refreshIcons();
                },
                submitJson() {
                    return JSON.stringify(this.blocks);
                },
                refreshIcons() {
                    setTimeout(() => {
                        if (typeof lucide !== 'undefined') lucide.createIcons();
                    }, 50);
                }
            };
        };
    })();
</script>
