@model PaginatedList<Product>
@*
    Admin: Danh sách sản phẩm — bảng dữ liệu, search, filter, bulk actions.
*@
@{
    ViewData["Title"] = "Quản lý sản phẩm";
    var categories = ViewData["Categories"] as List<Category> ?? new();
}

<div class="space-y-6">
    @* Header *@
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Quản lý sản phẩm</h1>
            <p class="text-gray-500 mt-1">@Model.TotalCount sản phẩm</p>
        </div>
        <a href="/admin/products/create"
           class="inline-flex items-center gap-2 bg-primary text-white px-5 py-2.5 rounded-lg font-medium hover:opacity-90 transition">
            <i data-lucide="plus" class="w-4 h-4"></i> Thêm sản phẩm
        </a>
    </div>

    @* Import/Export bar *@
    <div class="bg-white rounded-xl shadow-sm p-4 flex flex-wrap items-center gap-3">
        <a href="/admin/products-io/export" class="inline-flex items-center gap-2 px-4 py-2 text-sm bg-emerald-600 text-white rounded-lg hover:bg-emerald-700">
            <i data-lucide="file-spreadsheet" class="w-4 h-4"></i> Xuất Excel
        </a>
        <a href="/admin/products-io/template" class="inline-flex items-center gap-2 px-4 py-2 text-sm border border-gray-200 rounded-lg hover:bg-gray-50">
            <i data-lucide="file-down" class="w-4 h-4"></i> Tải template Excel
        </a>
        <form action="/admin/products-io/import" method="post" enctype="multipart/form-data" class="flex items-center gap-2 ml-auto">
            @Html.AntiForgeryToken()
            <input type="file" name="file" accept=".xlsx,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" required
                   class="text-sm text-gray-600 file:mr-2 file:py-1.5 file:px-3 file:rounded file:border-0 file:text-sm file:bg-primary/10 file:text-primary" />
            <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 text-sm bg-gray-700 text-white rounded-lg hover:bg-gray-800">
                <i data-lucide="upload" class="w-4 h-4"></i> Nhập Excel
            </button>
        </form>
    </div>

    @* Toast messages *@
    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg flex items-center gap-2 animate-fadeIn">
            <i data-lucide="check-circle" class="w-5 h-5"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg flex items-center gap-2 animate-fadeIn">
            <i data-lucide="alert-circle" class="w-5 h-5"></i> @TempData["Error"]
        </div>
    }

    @* Search + Filter bar *@
    <form method="get" class="bg-white rounded-xl shadow-sm p-4 flex flex-col sm:flex-row gap-3">
        <div class="relative flex-1">
            <input type="text" name="search" value="@ViewBag.Search"
                   placeholder="Tìm theo tên, SKU..."
                   class="w-full pl-10 pr-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary" />
            <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400"></i>
        </div>
        <select name="status" class="px-4 py-2 border border-gray-200 rounded-lg text-sm">
            <option value="">Tất cả trạng thái</option>
            <option value="Available" selected="@(ViewBag.Status == "Available")">Hiển thị</option>
            <option value="Hidden" selected="@(ViewBag.Status == "Hidden")">Ẩn</option>
            <option value="OutOfStock" selected="@(ViewBag.Status == "OutOfStock")">Hết hàng</option>
        </select>
        <button type="submit" class="px-5 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-200 transition">
            Lọc
        </button>
    </form>

    @* Product table *@
    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
                    <tr>
                        <th class="px-4 py-3 text-left">
                            <input type="checkbox" id="select-all" class="rounded" />
                        </th>
                        <th class="px-4 py-3 text-left">Sản phẩm</th>
                        <th class="px-4 py-3 text-left">Danh mục</th>
                        <th class="px-4 py-3 text-left">Giá</th>
                        <th class="px-4 py-3 text-center">Trạng thái</th>
                        <th class="px-4 py-3 text-center">Lượt xem</th>
                        <th class="px-4 py-3 text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var product in Model.Items)
                    {
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-4 py-3">
                                <input type="checkbox" name="ids" value="@product.Id" class="product-checkbox rounded" />
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex items-center gap-3">
                                    @if (!string.IsNullOrEmpty(product.Content?.Image))
                                    {
                                        <img src="@product.Content.Image" alt="" class="w-10 h-10 rounded-lg object-cover" />
                                    }
                                    else
                                    {
                                        <div class="w-10 h-10 bg-gray-100 rounded-lg flex items-center justify-center">
                                            <i data-lucide="image-off" class="w-4 h-4 text-gray-300"></i>
                                        </div>
                                    }
                                    <div>
                                        <a href="/admin/products/edit/@product.Id" class="font-medium text-gray-800 hover:text-primary">
                                            @product.Name
                                        </a>
                                        @if (!string.IsNullOrEmpty(product.Sku))
                                        {
                                            <p class="text-xs text-gray-400">@product.Sku</p>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td class="px-4 py-3 text-gray-500">
                                @(product.Category?.Name ?? "—")
                            </td>
                            <td class="px-4 py-3 font-medium">
                                @PriceHelper.FormatPrice(product.Finance?.Price)
                            </td>
                            <td class="px-4 py-3 text-center">
                                @switch (product.Status)
                                {
                                    case ProductStatus.Available:
                                        <span class="px-2 py-1 bg-green-100 text-green-600 rounded-full text-xs font-medium">Hiển thị</span>
                                        break;
                                    case ProductStatus.Hidden:
                                        <span class="px-2 py-1 bg-gray-100 text-gray-500 rounded-full text-xs font-medium">Ẩn</span>
                                        break;
                                    case ProductStatus.OutOfStock:
                                        <span class="px-2 py-1 bg-red-100 text-red-500 rounded-full text-xs font-medium">Hết hàng</span>
                                        break;
                                }
                            </td>
                            <td class="px-4 py-3 text-center text-gray-500">
                                @(product.Statistic?.ViewCount ?? 0)
                            </td>
                            <td class="px-4 py-3 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="@product.SeoUrl" target="_blank"
                                       class="p-1.5 text-gray-400 hover:text-primary rounded transition" title="Xem">
                                        <i data-lucide="external-link" class="w-4 h-4"></i>
                                    </a>
                                    <a href="/admin/products/edit/@product.Id"
                                       class="p-1.5 text-gray-400 hover:text-primary rounded transition" title="Sửa">
                                        <i data-lucide="pencil" class="w-4 h-4"></i>
                                    </a>
                                    <form method="post" action="/admin/products/delete/@product.Id"
                                          onsubmit="return confirm('Xóa sản phẩm này?');"
                                          class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="p-1.5 text-gray-400 hover:text-red-500 rounded transition" title="Xóa">
                                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* Bulk action bar *@
        <div id="bulk-bar" class="hidden border-t px-4 py-3 bg-gray-50 flex items-center gap-4">
            <span class="text-sm text-gray-600">Đã chọn <strong id="selected-count">0</strong> sản phẩm</span>
            <form method="post" action="/admin/products/bulk" id="bulk-form" class="flex gap-2">
                @Html.AntiForgeryToken()
                <div id="bulk-ids"></div>
                <button type="submit" name="action" value="show" class="px-3 py-1.5 bg-green-100 text-green-700 rounded text-sm hover:bg-green-200">Hiện</button>
                <button type="submit" name="action" value="hide" class="px-3 py-1.5 bg-gray-200 text-gray-700 rounded text-sm hover:bg-gray-300">Ẩn</button>
                <button type="submit" name="action" value="delete" class="px-3 py-1.5 bg-red-100 text-red-700 rounded text-sm hover:bg-red-200"
                        onclick="return confirm('Xóa tất cả sản phẩm đã chọn?');">Xóa</button>
            </form>
            <button type="button" id="bulk-edit-btn" class="px-3 py-1.5 bg-blue-100 text-blue-700 rounded text-sm hover:bg-blue-200 flex items-center gap-1">
                <i data-lucide="pencil" class="w-3 h-3"></i> Sửa giá hàng loạt
            </button>
        </div>

        @* Pagination *@
        @if (Model.TotalPages > 1)
        {
            <div class="border-t px-4 py-3 flex justify-center">
                <div class="flex items-center space-x-1">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <a href="?page=@i&search=@ViewBag.Search&status=@ViewBag.Status"
                           class="px-3 py-1.5 rounded text-sm @(i == Model.PageIndex ? "bg-primary text-white" : "text-gray-600 hover:bg-gray-100")">
                            @i
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Select all / bulk actions
        var selectAll = document.getElementById('select-all');
        var checkboxes = document.querySelectorAll('.product-checkbox');
        var bulkBar = document.getElementById('bulk-bar');
        var selectedCount = document.getElementById('selected-count');
        var bulkIds = document.getElementById('bulk-ids');

        function updateBulkBar() {
            var checked = document.querySelectorAll('.product-checkbox:checked');
            if (checked.length > 0) {
                bulkBar.classList.remove('hidden');
                selectedCount.textContent = checked.length;
                // Sync IDs to form
                bulkIds.innerHTML = '';
                checked.forEach(function(cb) {
                    var input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'ids';
                    input.value = cb.value;
                    bulkIds.appendChild(input);
                });
            } else {
                bulkBar.classList.add('hidden');
            }
        }

        selectAll.addEventListener('change', function() {
            checkboxes.forEach(function(cb) { cb.checked = selectAll.checked; });
            updateBulkBar();
        });

        checkboxes.forEach(function(cb) {
            cb.addEventListener('change', updateBulkBar);
        });

        // Bulk edit button — redirect to BulkEdit page with selected IDs
        document.getElementById('bulk-edit-btn')?.addEventListener('click', function() {
            var checked = document.querySelectorAll('.product-checkbox:checked');
            if (checked.length === 0) return;
            var params = Array.from(checked).map(function(cb) { return 'ids=' + cb.value; }).join('&');
            window.location.href = '/admin/products/bulkedit?' + params;
        });

        lucide.createIcons();
    </script>
}
