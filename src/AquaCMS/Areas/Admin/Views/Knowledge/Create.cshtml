@model Post
@{
    var isEdit = Model.Id != Guid.Empty;
    ViewData["Title"] = isEdit ? $"Sửa: {Model.Title}" : "Viết bài mới";
    var categories = ViewData["Categories"] as List<KnowledgeCategory> ?? new();
}

<div class="max-w-5xl space-y-6">
    <div class="flex items-center gap-4">
        <a href="/admin/knowledge" class="p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition">
            <i data-lucide="arrow-left" class="w-5 h-5"></i>
        </a>
        <h1 class="text-2xl font-bold text-gray-900">@ViewData["Title"]</h1>
    </div>

    <form method="post"
          action="@(isEdit ? $"/admin/knowledge/edit/{Model.Id}" : "/admin/knowledge/create")"
          enctype="multipart/form-data"
          class="space-y-6">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            @* ===== MAIN CONTENT (2/3) ===== *@
            <div class="lg:col-span-2 space-y-6">
                @* Tiêu đề *@
                <div class="bg-white rounded-xl shadow-sm p-6 space-y-5">
                    <div>
                        <label asp-for="Title" class="block text-sm font-medium text-gray-700 mb-1">
                            Tiêu đề <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="Title" required
                               class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary"
                               placeholder="VD: Hướng dẫn lắp đặt hệ thống sục khí" />
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="Slug" class="block text-sm font-medium text-gray-700 mb-1">Slug (URL)</label>
                            <input asp-for="Slug"
                                   class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                                   placeholder="Tự động tạo từ tiêu đề" />
                        </div>
                        <div>
                            <label asp-for="ReadTime" class="block text-sm font-medium text-gray-700 mb-1">Thời gian đọc</label>
                            <input asp-for="ReadTime"
                                   class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                                   placeholder="VD: 5 phút" />
                        </div>
                    </div>

                    <div>
                        <label asp-for="Excerpt" class="block text-sm font-medium text-gray-700 mb-1">Tóm tắt</label>
                        <textarea asp-for="Excerpt" rows="2"
                                  class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                                  placeholder="Mô tả ngắn hiện ở trang listing (2-3 câu)"></textarea>
                    </div>
                </div>

                @* Nội dung HTML — TinyMCE *@
                <div class="bg-white rounded-xl shadow-sm p-6">
                    <label class="block text-sm font-medium text-gray-700 mb-3">
                        Nội dung bài viết <span class="text-red-500">*</span>
                    </label>
                    <textarea asp-for="Content" id="editor-content" class="rich-editor w-full hidden">@Model.Content</textarea>
                </div>

                @* SEO *@
                <div class="bg-white rounded-xl shadow-sm p-6 space-y-5">
                    <h2 class="font-bold text-gray-800 text-lg border-b pb-3 flex items-center gap-2">
                        <i data-lucide="search" class="w-5 h-5 text-gray-400"></i> SEO
                    </h2>
                    <div>
                        <label asp-for="MetaTitle" class="block text-sm font-medium text-gray-700 mb-1">Meta Title</label>
                        <input asp-for="MetaTitle"
                               class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                               placeholder="Để trống = dùng tiêu đề bài viết" maxlength="70" />
                        <p class="text-xs text-gray-400 mt-1">Tối đa 70 ký tự</p>
                    </div>
                    <div>
                        <label asp-for="MetaDesc" class="block text-sm font-medium text-gray-700 mb-1">Meta Description</label>
                        <textarea asp-for="MetaDesc" rows="2"
                                  class="w-full px-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                                  placeholder="Để trống = dùng tóm tắt" maxlength="160"></textarea>
                        <p class="text-xs text-gray-400 mt-1">Tối đa 160 ký tự</p>
                    </div>
                </div>
            </div>

            @* ===== SIDEBAR (1/3) ===== *@
            <div class="space-y-6">
                @* Xuất bản *@
                <div class="bg-white rounded-xl shadow-sm p-6 space-y-4">
                    <h3 class="font-bold text-gray-800 border-b pb-3">Xuất bản</h3>

                    <div class="flex items-center gap-3">
                        <input asp-for="IsPublished" type="checkbox" class="rounded text-primary focus:ring-primary w-5 h-5" />
                        <label asp-for="IsPublished" class="text-sm text-gray-700 font-medium">Xuất bản ngay</label>
                    </div>

                    @if (isEdit && Model.PublishedAt.HasValue)
                    {
                        <p class="text-xs text-gray-400">
                            Xuất bản lúc: @Model.PublishedAt.Value.ToString("dd/MM/yyyy HH:mm")
                        </p>
                    }

                    <div class="flex gap-2 pt-2">
                        <button type="submit"
                                class="flex-1 bg-primary text-white px-4 py-2.5 rounded-lg font-medium hover:opacity-90 transition flex items-center justify-center gap-2">
                            <i data-lucide="save" class="w-4 h-4"></i>
                            @(isEdit ? "Cập nhật" : "Lưu bài")
                        </button>
                        <a href="/admin/knowledge" class="px-4 py-2.5 text-gray-500 hover:text-gray-700 border border-gray-200 rounded-lg transition text-center">
                            Hủy
                        </a>
                    </div>
                </div>

                @* Danh mục + tác giả *@
                <div class="bg-white rounded-xl shadow-sm p-6 space-y-4">
                    <h3 class="font-bold text-gray-800 border-b pb-3">Chi tiết</h3>

                    <div>
                        <label asp-for="KnowledgeCategoryId" class="block text-sm font-medium text-gray-700 mb-1">Danh mục</label>
                        <select asp-for="KnowledgeCategoryId"
                                class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50">
                            <option value="">— Không có —</option>
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.Id" selected="@(Model.KnowledgeCategoryId == cat.Id)">@cat.Name</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label asp-for="Author" class="block text-sm font-medium text-gray-700 mb-1">Tác giả</label>
                        <input asp-for="Author"
                               class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                               placeholder="Admin" />
                    </div>
                </div>

                @* Ảnh đại diện *@
                <div class="bg-white rounded-xl shadow-sm p-6 space-y-4">
                    <h3 class="font-bold text-gray-800 border-b pb-3">Ảnh đại diện</h3>
                    <div>
                        <label asp-for="Image" class="block text-sm font-medium text-gray-700 mb-1">URL ảnh</label>
                        <input asp-for="Image"
                               class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary/50"
                               placeholder="https://... hoặc /uploads/..." />
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Image))
                    {
                        <img id="kn-preview" src="@Model.Image" alt="Preview" class="w-full h-32 rounded-lg object-cover" />
                    }
                    else
                    {
                        <img id="kn-preview" src="" alt="Preview" class="w-full h-32 rounded-lg object-cover hidden" />
                    }
                    <div>
                        <label class="block text-xs text-gray-500 mb-1">Hoặc upload trực tiếp:</label>
                        <input type="file" name="imageFile" accept="image/*" data-preview="#kn-preview" data-crop="16:9"
                               class="block w-full text-sm text-gray-600 file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-primary/10 file:text-primary hover:file:bg-primary/20" />
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        lucide.createIcons();
        // Quill auto-initializes via _AdminLayout.cshtml (rich-editor class)
    </script>
}
